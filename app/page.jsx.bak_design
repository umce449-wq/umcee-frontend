fr:{dir:"ltr",langName:"Français",flag:"🇫🇷",nav:{about:"À propos",services:"Services",how:"Comment ça marche",pricing:"Tarifs",faq:"FAQ",login:"Connexion",register:"S'inscrire",back:"Retour",contact:"Contact",terms:"Conditions",privacy:"Confidentialité",blog:"Blog",help:"Aide"},hero:{badge:"La Plateforme N°1 de Gestion E-Commerce",t1:"Votre Indépendance",t2:"Commerciale Commence Ici",sub:"Gérez votre équipe, analysez vos profits et contrôlez votre activité de n'importe où dans le monde.",cta1:"Démarrer — 50 Commandes Gratuites",cta2:"Voir Comment Ça Marche",s1:"Marchands Actifs",s2:"Satisfaction Client %",s3:"Commandes Traitées"},pain:{title:"Savez-vous ce qui arrive à 90% des marchands?",sub:"Ils travaillent dur pendant des mois... puis découvrent la vérité",points:["Vendent sans connaître leur profit réel","L'équipe travaille aléatoirement","Pas d'analyses réelles","Veulent s'étendre sans outil"],solution:"UMCEM résout tous ces problèmes"},features:{title:"Tout en Un Seul Endroit",sub:"Système d'exploitation complet pour votre entreprise",items:[{title:"Simulation de Profits",desc:"Calculez votre profit réel avant de commencer."},{title:"Gestion d'Équipe",desc:"Assignez des tâches et donnez des permissions précises."},{title:"Système de Confirmation",desc:"3 jours × 3 sessions × 5 appels."},{title:"Connectez Vos Magasins",desc:"Shopify, YouCan, WooCommerce automatiquement."},{title:"Analyses en Temps Réel",desc:"Profits nets et performance produit."},{title:"Gestion des Risques",desc:"Alertes automatiques des pertes."},{title:"Fonctionne Partout",desc:"N'importe quel marché et devise."},{title:"Barre de Motivation",desc:"Interface agent motivante."}]},how:{title:"Commencez en 4 Étapes",steps:[{title:"Créez Votre Compte",desc:"Inscrivez-vous en 2 minutes et commencez avec 50 commandes gratuites"},{title:"Ajoutez Vos Produits",desc:"Ajoutez avec SKU et prix"},{title:"Connectez Votre Boutique",desc:"Copiez-collez la clé API"},{title:"Gérez et Grandissez",desc:"Décisions basées sur des données"}]},faq:{title:"Questions Fréquentes",items:[{q:"Ai-je besoin d'expérience technique?",a:"Non. Copier-coller une clé API suffit."},{q:"Plusieurs boutiques?",a:"Oui, Shopify, YouCan, WooCommerce."},{q:"Comment fonctionne la Simulation?",a:"Entrez les prix — 3 scénarios affichés."},{q:"Après l'essai gratuit?",a:"Notification 3 jours avant. Aucuns frais cachés."},{q:"Plusieurs langues?",a:"Arabe, anglais, français, espagnol, turc."},{q:"Données sécurisées?",a:"SSL. Jamais partagées."},{q:"Entreprises de livraison?",a:"Oui, Aramex, DHL, Bosta et autres."},{q:"Membres de l'équipe?",a:"3 pour Débutant, 10 pour Pro, illimité pour Business."}]},about:{title:"À Propos",sub:"UMCEM Est Née d'une Vraie Lutte",p1:"Des marchands ont travaillé dur pour découvrir qu'ils opéraient à perte.",p2:"UMCEM vous donne une indépendance commerciale complète.",mission:"Notre Mission",missionText:"Permettre à chaque marchand e-commerce de gérer son activité professionnellement.",vision:"Notre Vision",visionText:"Être la plateforme #1 mondiale de gestion e-commerce d'ici 2027.",values:"Nos Valeurs",valItems:["Transparence totale","Simplicité sans compromis","Sécurité et fiabilité","Support continu"]},cta:{title:"Commencez Aujourd'hui",sub:"50 commandes gratuites — sans frais",btn:"Commencer Gratuitement"},contact:{title:"Contactez-Nous",sub:"Nous répondrons dans les 24 heures.",nameL:"Nom Complet",nameP:"Votre nom",emailL:"Email",emailP:"example@domain.com",subjectL:"Sujet",subjectP:"Comment pouvons-nous vous aider?",msgL:"Message",msgP:"Écrivez votre message...",send:"Envoyer",sending:"Envoi...",sent:"Message envoyé!",sentSub:"Nous vous répondrons dans 24h.",officeTitle:"Informations de Contact",email:"support@UMCEM.io",phone:"+212 600 000 000",hours:"Disponible 24/7",social:"Suivez-nous"},terms:{title:"Conditions d'Utilisation",updated:"Dernière mise à jour: Janvier 2025",sections:[{title:"1. Acceptation",body:"En utilisant UMCEM, vous acceptez ces conditions."},{title:"2. Service",body:"UMCEM est une plateforme SaaS pour gérer le e-commerce."},{title:"3. Paiement",body:"Facturation mensuelle à l'avance. Annulation possible à tout moment."},{title:"4. Remboursement",body:"Garantie de remboursement dans les 7 jours."},{title:"5. Sécurité",body:"Chiffrement SSL. Données non partagées."},{title:"6. Propriété intellectuelle",body:"Tout le contenu est la propriété exclusive d'UMCEM."},{title:"7. Modifications",body:"Nous pouvons modifier ces conditions avec notification préalable."}]},privacy:{title:"Politique de Confidentialité",updated:"Dernière mise à jour: Janvier 2025",sections:[{title:"1. Données collectées",body:"Informations de compte, données d'utilisation, informations d'appareil."},{title:"2. Utilisation",body:"Pour fournir et améliorer le service."},{title:"3. Partage",body:"Jamais vendu à des tiers à des fins marketing."},{title:"4. Sécurité",body:"SSL, chiffrement de base de données, surveillance continue."},{title:"5. Vos droits",body:"Accès, correction, suppression. Contact: privacy@UMCEM.io"},{title:"6. Cookies",body:"Pour améliorer votre expérience."},{title:"7. Contact",body:"privacy@UMCEM.io"}]},help:{title:"Centre d'Aide",sub:"Tout ce que vous devez savoir sur UMCEM",categories:[{icon:"🚀",title:"Démarrage Rapide",desc:"Comment créer votre compte",articles:["Créer un compte","Connecter Shopify","Connecter YouCan","Connecter WooCommerce","Ajouter un produit"]},{icon:"👥",title:"Gestion d'Équipe",desc:"Ajouter des membres",articles:["Ajouter un agent","Définir les permissions","Suivi des performances","Distribution auto","Barre de motivation"]},{icon:"📊",title:"Analyses",desc:"Lire vos données",articles:["Tableau de bord","Simulation de Profits","Rapports PDF","Comparaisons","Analyse produits"]},{icon:"💳",title:"Abonnement",desc:"Paiements et factures",articles:["Changer de plan","Mettre à jour la carte","Télécharger factures","Annuler","Remboursement"]}],contactTitle:"Vous n'avez pas trouvé?",contactSub:"Notre équipe est disponible 24/7",contactBtn:"Contacter le Support"},blog:{title:"Blog",sub:"Derniers articles pour votre succès e-commerce",posts:[{cat:"Conseils",date:"15 Janvier 2025",title:"Comment atteindre 80% de confirmation?",desc:"Guide complet des stratégies de confirmation intelligente.",time:"5 min"},{cat:"Analyse",date:"10 Janvier 2025",title:"Pourquoi 90% des marchands perdent de l'argent?",desc:"Étude analytique des raisons d'échec des marchands.",time:"8 min"},{cat:"Tech",date:"5 Janvier 2025",title:"Connecter Shopify avec UMCEM: Guide étape par étape",desc:"Comment connecter votre boutique Shopify en moins de 5 minutes.",time:"4 min"},{cat:"Stratégie",date:"1 Janvier 2025",title:"Construire une équipe de vente réussie",desc:"Comment choisir et motiver votre équipe avec UMCEM.",time:"6 min"},{cat:"Conseils",date:"28 Décembre 2024",title:"Simulation de Profits: Calculez avant de commencer",desc:"Comment utiliser l'outil Simulation pour évaluer tout produit.",time:"5 min"},{cat:"Tech",date:"20 Décembre 2024",title:"Gestion des risques en e-commerce",desc:"Comment protéger votre entreprise des pertes.",time:"7 min"}],readMore:"Lire l'article",articles:[{id:1,cat:"Conseils",color:"#00D4AA",date:"15 Janvier 2025",time:"5 min",title:"Comment atteindre 80% de taux de confirmation?",desc:"Guide psychologique et strategique pour augmenter votre taux de confirmation.",body:"Vous payez pour la publicite. Votre equipe appelle. Les commandes arrivent.\nPuis vous decouvrez que 40% de vos commandes ont disparu.\n\nCe n'est pas un echec. C'est l'absence d'un systeme.\n\nJour Un:\n● Tentative matinale (8h-10h)\n● Tentative de midi (12h-14h)\n● Tentative du soir (18h-20h)\n\nJour Deux:\n● Deux tentatives avec un rappel SMS\n\nJour Trois:\n● Derniere tentative avec une offre speciale\n\n✅ Taux de confirmation de 43% a 79% en 30 jours\n✅ Economie de 3 heures par jour\n\nUMCEM vous donne ce systeme pret des le premier jour."},{id:2,cat:"Analyse",color:"#EF4444",date:"10 Janvier 2025",time:"8 min",title:"Pourquoi 90% des marchands perdent de l'argent sans le savoir?",desc:"La verite douloureuse revelee par une comptabilite correcte.",body:"Cet article va vous deranger.\nMais il pourrait sauver votre business.\n\nUn marchand vendant 400 commandes a 150 euros\nVentes totales = 60,000 euros\n\n● Cout produit = 18,000\n● Cout livraison = 8,800\n● Retours 25% = 6,700\n● Couts publicitaires = 16,000\n● Salaires = 9,000\n\nTotal = 61,000 euros\n❌ Perte nette = 1,000 euros par mois!\n\nUMCEM Simulation calcule votre profit net reel avant de vendre."},{id:3,cat:"Tech",color:"#818CF8",date:"5 Janvier 2025",time:"4 min",title:"Connecter Shopify avec UMCEM en 5 minutes",desc:"Guide technique etape par etape pour connecter votre boutique.",body:"Votre journee sans systeme:\n8h00 - Ouvrir Shopify\n8h15 - Copier manuellement dans Excel\n8h45 - Envoyer via WhatsApp\n\nEtapes de connexion:\n1. Shopify puis Parametres puis Apps\n2. Develop apps puis Create an app\n3. Nommez UMCEM, activez Orders read\n4. Copiez le token API\n5. UMCEM puis Boutiques puis Ajouter\n\n✅ 2-3 heures economisees par jour\n✅ Plus de commandes oubliees"},{id:4,cat:"Strategie",color:"#F59E0B",date:"1 Janvier 2025",time:"6 min",title:"Une equipe sans supervision = Un business qui saigne chaque jour",desc:"Comment decouvrir l'agent faible avant qu'il vous coute des milliers.",body:"Savez-vous combien d'appels chaque agent a passes aujourd'hui?\n\nSi non - vous perdez de l'argent maintenant.\n\nUn agent sans systeme travaille a 40% d'efficacite seulement.\n\nAvec UMCEM:\n● Tableau de performance en temps reel\n● Alerte instantanee quand les performances baissent\n● Rapport quotidien sur votre telephone\n\n✅ Taux de confirmation de 51% a 76%\n✅ Ventes en hausse de 43%"},{id:5,cat:"Conseils",color:"#00D4AA",date:"28 Decembre 2024",time:"5 min",title:"Simulation: Ne vendez jamais sans connaitre vos chiffres",desc:"Comment utiliser les chiffres pas la chance pour choisir vos produits.",body:"Exemple reel - Montre connectee:\n● Achat: 85 euros / Vente: 220 / Livraison: 25 / Pub: 42 / Retours: 20%\n\nSans Simulation: 220 - 85 = 135 euros de profit!\n\nAvec Simulation:\n✅ Meilleur cas (80%): 43 euros profit\n⚡ Cas prevu (60%): 24 euros profit\n❌ Pire cas (40%): 12 euros de perte\n\nNe lancez jamais une campagne avant que Simulation dise rentable."},{id:6,cat:"Tech",color:"#EF4444",date:"20 Decembre 2024",time:"7 min",title:"Gestion des risques: Sachez avant qu'il soit trop tard",desc:"Le systeme qui protege votre business des pertes silencieuses.",body:"Il existe une perte plus dangereuse que la perte evidente.\nC'est la perte silencieuse.\n\nUn marchand a perdu 34,000 euros en 3 mois sans le savoir.\n\nUMCEM alerte automatiquement quand:\n⚠️ Taux de retour depasse votre limite\n⚠️ Produit en zone de perte\n⚠️ Taux de confirmation trop bas\n⚠️ Couts pub en hausse sans resultats\n\nAlertes via tableau de bord, SMS et email.\nUMCEM vous fait toujours savoir en premier."}]},login:{title:"Bon Retour",sub:"Connectez-vous pour continuer",eL:"Email",eP:"example@domain.com",pL:"Mot de Passe",pP:"Votre mot de passe",forgot:"Mot de passe oublié?",btn:"Connexion",noAcc:"Pas de compte?",regLink:"Créer un Compte",brand:"Gérez votre équipe et analysez vos profits de partout"},reg:{title:"Créez Votre Compte",sub:"Commencez vers l'indépendance",s1:"Informations Personnelles",s2:"Vérification Téléphone & Carte",s3:"Choisissez Votre Plan",fnL:"Prénom",fnP:"ex: Jean",lnL:"Nom",lnP:"ex: Dupont",eL:"Email",eP:"example@domain.com",phL:"Téléphone",phP:"Votre numéro",codeL:"Indicatif",cL:"Pays",cP:"— Sélectionnez —",pL:"Mot de Passe",pP:"8 caractères min",bL:"Nom de l'Entreprise",bP:"ex: Ma Boutique",storeType:"Type de Boutique",next:"Suivant",prev:"Retour",submit:"Commencer",hasAcc:"Déjà un compte?",loginLink:"Connexion",docTitle:"Vérification d'Identité",docSub:"Téléchargez un document (Requis)",idCard:"Carte d'Identité",pp:"Passeport",front:"Face Avant",back:"Face Arrière",uploadHint:"JPG, PNG ou PDF — Max 5MB",secNote:"Protégé par SSL",done:"Compte Créé!",doneSub:"Documents examinés dans 24h.",choosePlan:"Choisissez Votre Plan",errReq:"Remplissez tous les champs",errPass:"8 caractères minimum",errDoc:"Téléchargez un document valide",bestLabel:"Meilleur",chooseFile:"Cliquer pour télécharger",freeNote:"50 commandes gratuites"},pricing:{title:"Choisissez Votre Plan",sub:"50 commandes gratuites — sans frais",popular:"Le Plus Populaire",monthly:"/mois",trialNote:"50 commandes gratuites",payTitle:"Finaliser l'Abonnement",cnL:"Numéro de Carte",cnP:"0000 0000 0000 0000",exL:"Expiration",exP:"MM/AA",cvL:"CVV",cvP:"•••",nmL:"Nom sur la Carte",nmP:"Nom complet",payBtn:"Payer",backBtn:"Retour",secure:"Paiement sécurisé SSL",orderSum:"Résumé",plan:"Plan",total:"Total",success:"Paiement Réussi!",successSub:"Bienvenue sur UMCEM.",goDash:"Tableau de Bord",errCard:"Données carte incomplètes",features:"Fonctionnalités",startNow:"Commencer",startFree:"Essai Gratuit",contactUs:"Nous Contacter",plans:[{id:"s",name:"Débutant",en:"Starter",price:"29.99",color:"#64748b",desc:"Pour commencer",features:["1 000 commandes/mois","3 membres","1 boutique","Analyses de base","Simulation","Support email"],cta:"startNow"},{id:"p",name:"Pro",en:"Pro",price:"59.99",popular:true,color:"#00D4AA",desc:"Pour grandir",features:["5 000 commandes/mois","10 membres","5 boutiques","Analyses avancées","Système 3 jours","Simulation avancée","SMS auto","Support 24/7"],cta:"startFree"},{id:"b",name:"Business",en:"Business",price:"99.99",color:"#818CF8",desc:"Pour grands projets",features:["Illimité","Équipe illimitée","Boutiques illimitées","PDF auto","API complet","Gestionnaire dédié","White-label","VIP"],cta:"contactUs"}]},footer:{tagline:"Votre indépendance commence ici",copy:"© 2025 UMCEM. Tous droits réservés.",p:"Plateforme",c:"Entreprise",s:"Support",pl:["Fonctionnalités","Tarifs","Simulation","Intégrations"],cl:["À Propos","Blog","Partenaires","Contactez-nous"],sl:["Centre d'aide","FAQ","Conditions d'utilisation","Confidentialité"]},
