            <div style={{display:"flex",gap:8}}>
              {[[Twitter,"#1DA1F2"],[Linkedin,"#0A66C2"],[Facebook,"#1877F2"],[Instagram,"#E4405F"],[Youtube,"#FF0000"]].map(([Ic,col],i)=>(
                <div key={i} style={{width:32,height:32,borderRadius:8,background:C.card,border:`1px solid ${C.border}`,display:"flex",alignItems:"center",justifyContent:"center",cursor:"pointer",transition:"all .2s"}} onMouseEnter={e=>{e.currentTarget.style.borderColor=col;e.currentTarget.style.background=`${col}15`;}} onMouseLeave={e=>{e.currentTarget.style.borderColor=C.border;e.currentTarget.style.background=C.card;}}><Ic size={14} color={C.muted} strokeWidth={1.8}/></div>
              ))}
              </div>
              <span style={{color:C.muted,fontSize:11}}>© {new Date().getFullYear()} UMCEM. {lang==="ar"?"جميع الحقوق محفوظة.":lang==="fr"?"Tous droits réservés.":lang==="es"?"Todos los derechos reservados.":lang==="tr"?"Tüm hakları saklıdır.":"All rights reserved."}</span>
            </div>
          </div>
          {/* ✅ Footer links now navigate to real pages */}
          <div>
            <h4 style={{fontWeight:800,marginBottom:12,fontSize:13,color:C.text}}>{t.footer.p}</h4>
            <ul style={{listStyle:"none",padding:0,margin:0,display:"flex",flexDirection:"column",gap:8}}>
              {[["features",t.footer.pl[0]],["pricing",t.footer.pl[1]],["simulation",t.footer.pl[2]],["stores",t.footer.pl[3]]].map(([action,label],j)=>(
                <li key={j}><a onClick={e=>{e.preventDefault();if(action==="features"){goPage("home");setTimeout(()=>{document.getElementById("services")?.scrollIntoView({behavior:"smooth"});},200);}else if(action==="pricing"){goPage("pricing");setPView("plans");}else if(action==="simulation"){goPage("pricing");setPView("plans");}else if(action==="stores"){goPage("home");setTimeout(()=>{document.getElementById("howItWorks")?.scrollIntoView({behavior:"smooth"});},200);}}} href="#" style={{color:C.sub,textDecoration:"none",fontSize:13,transition:"color .2s",cursor:"pointer"}} onMouseEnter={e=>e.target.style.color=A} onMouseLeave={e=>e.target.style.color=C.sub}>{label}</a></li>
              ))}
            </ul>
          </div>
          <div>
            <h4 style={{fontWeight:800,marginBottom:12,fontSize:13,color:C.text}}>{t.footer.c}</h4>
            <ul style={{listStyle:"none",padding:0,margin:0,display:"flex",flexDirection:"column",gap:8}}>
              {[["about",t.footer.cl[0]],["blog",t.footer.cl[1]],["contact",t.footer.cl[3]]].map(([pg,label],j)=>(
                <li key={j}><a onClick={e=>{e.preventDefault();goPage(pg);}} href="#" style={{color:C.sub,textDecoration:"none",fontSize:13,transition:"color .2s",cursor:"pointer"}} onMouseEnter={e=>e.target.style.color=A} onMouseLeave={e=>e.target.style.color=C.sub}>{label}</a></li>
              ))}
            </ul>
          </div>
          <div>
            <h4 style={{fontWeight:800,marginBottom:12,fontSize:13,color:C.text}}>{t.footer.s}</h4>
            <ul style={{listStyle:"none",padding:0,margin:0,display:"flex",flexDirection:"column",gap:8}}>
              {[["help",t.footer.sl[0]],["home",t.footer.sl[1]],["terms",t.footer.sl[2]],["privacy",t.footer.sl[3]]].map(([pg,label],j)=>(
                <li key={j}><a onClick={e=>{e.preventDefault();goPage(pg);}} href="#" style={{color:C.sub,textDecoration:"none",fontSize:13,transition:"color .2s",cursor:"pointer"}} onMouseEnter={e=>e.target.style.color=A} onMouseLeave={e=>e.target.style.color=C.sub}>{label}</a></li>
              ))}
            </ul>
          </div>
        </div>
        
      </div>
    </footer>
  );

  /* ════════════ HOME ════════════ */
  const Home=(
    <div style={{background:C.bg,color:C.text,direction:t.dir}}>
      {/* HERO */}
      <section id="home" style={{minHeight:"100vh",display:"flex",flexDirection:"column",alignItems:"center",justifyContent:"center",textAlign:"center",padding:"clamp(80px,10vw,120px) 5% 60px",position:"relative",overflow:"hidden"}}>
        <div style={{position:"absolute",top:"8%",left:"3%",width:"min(500px,80vw)",height:"min(500px,80vw)",borderRadius:"50%",background:"radial-gradient(circle,rgba(0,212,170,0.09),transparent 70%)",pointerEvents:"none"}}/>
        <div style={{position:"absolute",bottom:"8%",right:"3%",width:"min(400px,70vw)",height:"min(400px,70vw)",borderRadius:"50%",background:"radial-gradient(circle,rgba(129,140,248,0.09),transparent 70%)",pointerEvents:"none"}}/>
        <div style={{position:"absolute",inset:0,opacity:dark?.035:.05,backgroundImage:`linear-gradient(${C.border} 1px,transparent 1px),linear-gradient(90deg,${C.border} 1px,transparent 1px)`,backgroundSize:"60px 60px",pointerEvents:"none"}}/>
        <div style={{display:"inline-flex",alignItems:"center",gap:8,background:"rgba(0,212,170,0.12)",border:"1px solid rgba(0,212,170,0.28)",borderRadius:50,padding:"6px 18px",marginBottom:28,fontSize:13,fontWeight:700,color:A}}>
          <Star size={13} strokeWidth={2.5}/>{t.hero.badge}
        </div>
        <h1 style={{fontSize:"clamp(34px,6vw,82px)",fontWeight:900,lineHeight:1.1,marginBottom:22,letterSpacing:-2}}>
          <span style={{color:A}}>{t.hero.t1}</span><br/><span style={{color:C.text}}>{t.hero.t2}</span>
        </h1>
        <p style={{fontSize:"clamp(15px,2vw,19px)",maxWidth:640,color:C.sub,lineHeight:1.85,marginBottom:42}}>{t.hero.sub}</p>
        <div style={{display:"flex",gap:14,flexWrap:"wrap",justifyContent:"center",marginBottom:68}}>
          <button onClick={()=>{goPage("register");setRStep(1);setRErr("");setRDone(false);}} style={{padding:"14px 32px",borderRadius:12,background:"linear-gradient(135deg,#00D4AA,#00b896)",border:"none",color:"#fff",fontSize:15,fontWeight:800,cursor:"pointer",boxShadow:"0 8px 28px rgba(0,212,170,0.40)",transition:"all .2s",display:"flex",alignItems:"center",gap:8}} onMouseEnter={e=>e.currentTarget.style.transform="translateY(-3px)"} onMouseLeave={e=>e.currentTarget.style.transform="translateY(0)"}>
            {t.hero.cta1}{isRtl?<ArrowLeft size={16} strokeWidth={2.5}/>:<ArrowRight size={16} strokeWidth={2.5}/>}
          </button>
          <a href="#howItWorks" style={{padding:"14px 32px",borderRadius:12,background:"transparent",border:`1.5px solid ${C.border}`,color:C.text,fontSize:15,fontWeight:600,textDecoration:"none",transition:"all .2s",display:"flex",alignItems:"center",gap:8}} onMouseEnter={e=>{e.currentTarget.style.borderColor=A;e.currentTarget.style.color=A;}} onMouseLeave={e=>{e.currentTarget.style.borderColor=C.border;e.currentTarget.style.color=C.text;}}>
            <Target size={15} strokeWidth={2}/>{t.hero.cta2}
          </a>
        </div>
        <div style={{display:"flex",gap:"clamp(28px,5vw,56px)",flexWrap:"wrap",justifyContent:"center"}}>
          {[[2847,t.hero.s1,"+"],[98,t.hero.s2,"%"],[1200000,t.hero.s3,""]].map(([num,label,sfx],i)=>(
            <div key={i} style={{textAlign:"center"}}>
              <div style={{fontSize:"clamp(28px,4vw,44px)",fontWeight:900,color:A,lineHeight:1}}><AnimatedNumber target={num} suffix={sfx}/></div>
              <div style={{color:C.sub,fontSize:13,marginTop:6,fontWeight:600}}>{label}</div>
            </div>
          ))}
        </div>
      </section>

      {/* PAIN */}
      <section style={{padding:"72px 5%",background:dark?"rgba(255,50,50,0.04)":"#fff5f5",borderTop:"1px solid rgba(220,38,38,0.12)",borderBottom:"1px solid rgba(220,38,38,0.12)"}}>
        <div style={{maxWidth:940,margin:"0 auto",textAlign:"center"}}>
          <h2 style={{fontSize:"clamp(18px,4vw,42px)",fontWeight:900,marginBottom:12,color:C.text}}>{t.pain.title}</h2>
          <p style={{color:C.sub,fontSize:17,marginBottom:40}}>{t.pain.sub}</p>
          <div style={{display:"grid",gridTemplateColumns:"repeat(auto-fit,minmax(210px,1fr))",gap:16,marginBottom:36}}>
            {t.pain.points.map((pt,i)=>{const Ic=PICONS[i];return(<div key={i} style={{background:dark?"rgba(255,50,50,0.08)":"#fff",border:"1px solid rgba(220,38,38,0.15)",borderRadius:16,padding:"20px 16px",display:"flex",flexDirection:"column",alignItems:"center",gap:10,boxShadow:dark?"none":"0 2px 12px rgba(220,38,38,0.07)"}}>
              <div style={{width:44,height:44,borderRadius:12,background:"rgba(239,68,68,0.12)",display:"flex",alignItems:"center",justifyContent:"center"}}><Ic size={20} color="#EF4444" strokeWidth={1.8}/></div>
              <p style={{fontSize:13,lineHeight:1.75,color:C.sub,textAlign:"center"}}>{pt}</p>
            </div>);})}
          </div>
          <div style={{background:"linear-gradient(135deg,rgba(0,212,170,0.14),rgba(129,140,248,0.14))",border:"1px solid rgba(0,212,170,0.28)",borderRadius:14,padding:"15px 24px",fontSize:16,fontWeight:800,color:A,display:"flex",alignItems:"center",justifyContent:"center",gap:10}}>
            <Shield size={18} strokeWidth={2}/>{t.pain.solution}
          </div>
        </div>
      </section>

      {/* ABOUT */}
      <section id="about" style={{padding:"72px 5%",background:C.bg}}>
        <div style={{maxWidth:780,margin:"0 auto",textAlign:"center"}}>
          <h2 style={{fontSize:"clamp(18px,4vw,42px)",fontWeight:900,marginBottom:12,color:C.text}}>{t.about.title}</h2>
          <p style={{color:A,fontSize:18,fontWeight:700,marginBottom:20}}>{t.about.sub}</p>
          <p style={{color:C.sub,fontSize:16,lineHeight:1.85,marginBottom:12}}>{t.about.p1}</p>
          <p style={{color:C.sub,fontSize:16,lineHeight:1.85}}>{t.about.p2}</p>
        </div>
      </section>

      {/* FEATURES */}
      <section id="services" style={{padding:"72px 5%",background:C.bgS}}>
        <div style={{maxWidth:1200,margin:"0 auto"}}>
          <div style={{textAlign:"center",marginBottom:48}}>
            <h2 style={{fontSize:"clamp(18px,4vw,42px)",fontWeight:900,marginBottom:10,color:C.text}}>{t.features.title}</h2>
            <p style={{color:C.sub,fontSize:16}}>{t.features.sub}</p>
          </div>
          <div style={{display:"grid",gridTemplateColumns:"repeat(auto-fit,minmax(250px,1fr))",gap:16}}>
            {t.features.items.map((f,i)=>{const Ic=FICONS[i];const col=FCOLORS[i];return(
              <div key={i} style={{background:C.card,border:`1px solid ${C.border}`,borderRadius:18,padding:"22px 18px",transition:"all .3s",boxShadow:C.cardSh}} onMouseEnter={e=>{e.currentTarget.style.borderColor=col;e.currentTarget.style.transform="translateY(-4px)";e.currentTarget.style.boxShadow=`0 20px 40px ${col}18`;}} onMouseLeave={e=>{e.currentTarget.style.borderColor=C.border;e.currentTarget.style.transform="translateY(0)";e.currentTarget.style.boxShadow=C.cardSh;}}>
                <div style={{width:44,height:44,borderRadius:11,background:`${col}18`,display:"flex",alignItems:"center",justifyContent:"center",marginBottom:12}}><Ic size={21} color={col} strokeWidth={1.8}/></div>
                <h3 style={{fontWeight:800,fontSize:15,marginBottom:7,color:C.text}}>{f.title}</h3>
                <p style={{color:C.sub,fontSize:13,lineHeight:1.7}}>{f.desc}</p>
              </div>
            );})}
          </div>
        </div>
      </section>

      {/* HOW IT WORKS */}
      <section id="howItWorks" style={{padding:"72px 5%",background:C.bg}}>
        <div style={{maxWidth:960,margin:"0 auto"}}>
          <h2 style={{fontSize:"clamp(18px,4vw,42px)",fontWeight:900,textAlign:"center",marginBottom:48,color:C.text}}>{t.how.title}</h2>
          <div style={{display:"grid",gridTemplateColumns:"repeat(auto-fit,minmax(200px,1fr))",gap:26}}>
            {t.how.steps.map((s,i)=>{const Ic=SICONS[i];return(
              <div key={i} style={{textAlign:"center"}}>
                <div style={{width:64,height:64,borderRadius:"50%",margin:"0 auto 16px",background:"linear-gradient(135deg,rgba(0,212,170,0.14),rgba(129,140,248,0.14))",border:"2px solid rgba(0,212,170,0.28)",display:"flex",alignItems:"center",justifyContent:"center",position:"relative"}}>
                  <Ic size={24} color={A} strokeWidth={1.8}/>
                  <div style={{position:"absolute",top:-8,right:-8,width:22,height:22,borderRadius:"50%",background:A,display:"flex",alignItems:"center",justifyContent:"center",fontSize:10,fontWeight:900,color:"#fff"}}>0{i+1}</div>
                </div>
                <h3 style={{fontWeight:800,fontSize:15,marginBottom:7,color:C.text}}>{s.title}</h3>
                <p style={{color:C.sub,fontSize:13,lineHeight:1.7}}>{s.desc}</p>
              </div>
            );})}
          </div>
        </div>
      </section>

      {/* PRICING ON HOME */}
      <section id="pricing-sec" style={{padding:"72px 5%",background:C.bgS}}>
        <div style={{maxWidth:1100,margin:"0 auto"}}>
          <div style={{textAlign:"center",marginBottom:48}}>
            <h2 style={{fontSize:"clamp(18px,4vw,42px)",fontWeight:900,marginBottom:10,color:C.text}}>{t.pricing.title}</h2>
            <p style={{color:C.sub,fontSize:16}}>{t.pricing.sub}</p>
          </div>
          <div style={{display:"grid",gridTemplateColumns:"repeat(auto-fit,minmax(280px,1fr))",gap:22,alignItems:"center"}}>
            {t.pricing.plans.map((plan,i)=>{const col=PCOLS[i];return(
              <div key={plan.id} style={{background:plan.popular?`linear-gradient(145deg,${col}15,${col}08)`:C.card,border:plan.popular?`2px solid ${col}`:`1px solid ${C.border}`,borderRadius:22,padding:"1.8rem",position:"relative",transition:"transform .3s,box-shadow .3s",transform:plan.popular?"scale(1.04)":"scale(1)",boxShadow:plan.popular?`0 12px 48px ${col}25`:(dark?"none":C.cardSh)}} onMouseEnter={e=>{e.currentTarget.style.transform=plan.popular?"scale(1.07)":"scale(1.02)";}} onMouseLeave={e=>{e.currentTarget.style.transform=plan.popular?"scale(1.04)":"scale(1)";}}>
                {plan.popular&&<div style={{position:"absolute",top:-15,left:"50%",transform:"translateX(-50%)",background:col,color:"#fff",borderRadius:20,padding:"5px 18px",fontSize:12,fontWeight:800,whiteSpace:"nowrap",display:"flex",alignItems:"center",gap:6,boxShadow:`0 4px 12px ${col}40`}}><Star size={11} strokeWidth={2.5}/>{t.pricing.popular}</div>}
                <div style={{fontSize:11,color:col,fontWeight:800,marginBottom:6,letterSpacing:1,textTransform:"uppercase"}}>{plan.en}</div>
                <div style={{fontSize:23,fontWeight:900,marginBottom:5,color:C.text}}>{plan.name}</div>
                <div style={{fontSize:13,color:C.sub,marginBottom:18}}>{plan.desc}</div>
                <div style={{display:"flex",alignItems:"baseline",gap:4,marginBottom:20}}>
                  <span style={{fontSize:42,fontWeight:900,color:col,lineHeight:1}}>${plan.price}</span>
                  <span style={{fontSize:13,color:C.muted}}>{t.pricing.monthly}</span>
                </div>
                <ul style={{listStyle:"none",padding:0,margin:"0 0 22px",display:"flex",flexDirection:"column",gap:9}}>
                  {plan.features.map((f,j)=>(<li key={j} style={{display:"flex",alignItems:"center",gap:9,fontSize:13}}><div style={{width:17,height:17,borderRadius:"50%",background:`${col}20`,display:"flex",alignItems:"center",justifyContent:"center",flexShrink:0}}><Check size={9} color={col} strokeWidth={3}/></div><span style={{color:C.sub}}>{f}</span></li>))}
                </ul>
                <button onClick={()=>{if(plan.cta==="contactUs"){goPage("contact");return;}setSelPlan(plan);setCard({num:"",exp:"",cvc:"",name:""});setCardErr("");setPayLoad(false);setPayDone(false);setPView("payment");goPage("pricing");}} style={{width:"100%",padding:"12px 0",borderRadius:12,background:plan.popular?col:"transparent",color:plan.popular?"#fff":col,border:plan.popular?"none":`2px solid ${col}`,fontSize:14,fontWeight:800,cursor:"pointer",transition:"opacity .2s",boxShadow:plan.popular?`0 6px 20px ${col}40`:"none"}} onMouseEnter={e=>e.currentTarget.style.opacity=".85"} onMouseLeave={e=>e.currentTarget.style.opacity="1"}>
                  {t.pricing[plan.cta]}
                </button>
              </div>
            );})}
          </div>
          <div style={{textAlign:"center",marginTop:22,display:"flex",alignItems:"center",justifyContent:"center",gap:7,color:C.muted,fontSize:13}}>
            <Shield size={13} color={A} strokeWidth={2}/>{t.pricing.trialNote}
          </div>
        </div>
      </section>

      {/* FAQ */}
      <section id="faq" style={{padding:"72px 5%",background:C.bg}}>
        <div style={{maxWidth:780,margin:"0 auto"}}>
          <h2 style={{fontSize:"clamp(18px,4vw,42px)",fontWeight:900,textAlign:"center",marginBottom:40,color:C.text}}>{t.faq.title}</h2>
          <div style={{display:"flex",flexDirection:"column",gap:9}}>
            {t.faq.items.map((item,i)=>(
              <div key={i} style={{background:C.card,border:`1px solid ${faqOpen===i?A:C.border}`,borderRadius:13,overflow:"hidden",transition:"border-color .2s",boxShadow:C.cardSh}}>
                <button onClick={()=>setFaqOpen(faqOpen===i?null:i)} style={{width:"100%",padding:"17px 20px",background:"transparent",border:"none",color:C.text,fontFamily:"inherit",fontSize:15,fontWeight:700,cursor:"pointer",display:"flex",justifyContent:"space-between",alignItems:"center",gap:12}}>
                  <span style={{textAlign:isRtl?"right":"left"}}>{item.q}</span>
                  {faqOpen===i?<ChevronUp size={17} color={A} strokeWidth={2}/>:<ChevronDown size={17} color={C.muted} strokeWidth={2}/>}
                </button>
                {faqOpen===i&&<div style={{padding:"0 20px 16px",color:C.sub,fontSize:14,lineHeight:1.85}}>{item.a}</div>}
              </div>
            ))}
          </div>
        </div>
      </section>

      {/* CTA */}
      <section style={{padding:"64px 5%",margin:"0 5% 64px",background:"linear-gradient(135deg,rgba(0,212,170,0.11),rgba(129,140,248,0.11))",border:"1px solid rgba(0,212,170,0.20)",borderRadius:28,textAlign:"center"}}>
        <h2 style={{fontSize:"clamp(18px,4vw,38px)",fontWeight:900,marginBottom:12,color:C.text}}>{t.cta.title}</h2>
        <p style={{color:C.sub,fontSize:16,marginBottom:28}}>{t.cta.sub}</p>
        <button onClick={()=>{goPage("register");setRStep(1);setRErr("");setRDone(false);}} style={{padding:"13px 40px",borderRadius:12,background:"linear-gradient(135deg,#00D4AA,#818CF8)",border:"none",color:"#fff",fontSize:15,fontWeight:900,cursor:"pointer",boxShadow:"0 8px 28px rgba(0,212,170,0.38)"}}>{t.cta.btn}</button>
      </section>

      {Footer}
    </div>
  );

  /* ════════════ LOGIN ════════════ */
  const Login=(
    <div style={{background:C.bg,color:C.text,direction:t.dir,minHeight:"100vh",display:"flex",flexDirection:"column"}}>
      <div style={{flex:1,display:"flex",minHeight:"calc(100vh - 68px)"}}>
        <div className="ll" style={{flex:"0 0 45%",background:dark?"linear-gradient(145deg,#0a0a22,#0f0f2e)":"linear-gradient(145deg,#f0f4ff,#e8edff)",borderRight:`1px solid ${C.border}`,padding:"60px 40px",display:"flex",flexDirection:"column",justifyContent:"center",alignItems:"center",textAlign:"center"}}>
          <div style={{width:84,height:84,borderRadius:22,background:"linear-gradient(135deg,#00D4AA,#818CF8)",display:"flex",alignItems:"center",justifyContent:"center",marginBottom:28,boxShadow:"0 12px 40px rgba(0,212,170,0.4)"}}></div>
          <h2 style={{fontSize:"clamp(18px,2.5vw,26px)",fontWeight:900,marginBottom:12,color:C.text}}>UMCEM</h2>
          <p style={{color:C.sub,fontSize:15,lineHeight:1.8,maxWidth:280,marginBottom:40}}>{t.login.brand}</p>
          <div style={{display:"flex",gap:22,flexWrap:"wrap",justifyContent:"center"}}>
            {[[TrendingUp,"2,847+",t.hero.s1,A],[Shield,"98%",t.hero.s2,"#818CF8"],[Users,"1.2M+",t.hero.s3,"#F59E0B"]].map(([Ic,num,label,col],i)=>(
              <div key={i} style={{textAlign:"center"}}>
                <div style={{width:42,height:42,borderRadius:11,background:`${col}18`,border:`1px solid ${col}30`,display:"flex",alignItems:"center",justifyContent:"center",margin:"0 auto 9px"}}><Ic size={19} color={col} strokeWidth={1.8}/></div>
                <div style={{fontSize:19,fontWeight:900,color:col}}>{num}</div>
                <div style={{color:C.sub,fontSize:11,marginTop:2,fontWeight:600}}>{label}</div>
              </div>
            ))}
          </div>
        </div>
        <div style={{flex:1,display:"flex",alignItems:"center",justifyContent:"center",padding:"40px 24px"}}>
          <div style={{width:"100%",maxWidth:420}}>
            <BackBtn/>
            <h1 style={{fontSize:"clamp(22px,3vw,30px)",fontWeight:900,marginBottom:8,color:C.text}}>{t.login.title}</h1>
            <p style={{color:C.sub,fontSize:15,marginBottom:28,lineHeight:1.6}}>{t.login.sub}</p>
            <div style={{display:"flex",flexDirection:"column",gap:20}}>
              <div>
                <div style={{fontSize:13,fontWeight:700,marginBottom:8,color:C.text}}>{t.login.eL}</div>
                <input type="email" value={lEmail} onChange={e=>setLEmail(e.target.value)} placeholder={t.login.eP} style={bi} onFocus={e=>e.target.style.borderColor=A} onBlur={e=>e.target.style.borderColor=C.inpB}/>
              </div>
              <div>
                <div style={{display:"flex",justifyContent:"space-between",alignItems:"center",marginBottom:8}}>
                  <div style={{fontSize:13,fontWeight:700,color:C.text}}>{t.login.pL}</div>
                  <a href="#" style={{color:A,fontSize:12,textDecoration:"none",fontWeight:600}}>{t.login.forgot}</a>
                </div>
                <div style={{position:"relative"}}>
                  <input type={showP?"text":"password"} value={lPass} onChange={e=>setLPass(e.target.value)} placeholder={t.login.pP} style={{...bi,paddingRight:isRtl?"14px":"42px",paddingLeft:isRtl?"42px":"14px"}} onFocus={e=>e.target.style.borderColor=A} onBlur={e=>e.target.style.borderColor=C.inpB}/>
                  <button type="button" onClick={()=>setShowP(!showP)} style={{position:"absolute",[isRtl?"left":"right"]:12,top:"50%",transform:"translateY(-50%)",background:"transparent",border:"none",cursor:"pointer",color:C.muted,display:"flex"}}>{showP?<EyeOff size={15} strokeWidth={1.8}/>:<Eye size={15} strokeWidth={1.8}/>}</button>
                </div>
              </div>
              {lErr&&<div style={{padding:"10px 14px",borderRadius:9,background:"rgba(239,68,68,0.10)",border:"1px solid rgba(239,68,68,0.25)",color:"#EF4444",fontSize:13,fontWeight:600,display:"flex",alignItems:"center",gap:8}}><AlertCircle size={14} strokeWidth={2}/>{lErr}</div>}
              <button onClick={()=>{if(!lEmail||!lPass){setLErr(t.reg.errReq);return;}setLErr("");setLLoad(true);setTimeout(()=>setLLoad(false),1500);}} disabled={lLoad} style={{padding:"13px",borderRadius:12,border:"none",background:lLoad?"rgba(0,212,170,0.5)":"linear-gradient(135deg,#00D4AA,#818CF8)",color:"#fff",fontSize:15,fontWeight:800,cursor:lLoad?"not-allowed":"pointer",boxShadow:"0 6px 20px rgba(0,212,170,0.35)",transition:"all .2s",display:"flex",alignItems:"center",justifyContent:"center",gap:8}}>
                {lLoad?<div style={{width:18,height:18,border:"2px solid rgba(255,255,255,0.3)",borderTopColor:"#fff",borderRadius:"50%",animation:"spin .8s linear infinite"}}/>:t.login.btn}
              </button>
              <p style={{textAlign:"center",color:C.sub,fontSize:14}}>
                {t.login.noAcc}{" "}<button onClick={()=>{goPage("register");setRStep(1);setRErr("");setRDone(false);}} style={{background:"none",border:"none",color:A,cursor:"pointer",fontWeight:800,fontSize:14}}>{t.login.regLink}</button>
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  );

  /* ════════════ REGISTER ════════════ */
  const rf=(k,v)=>setRForm(f=>({...f,[k]:v}));
  const valR1=()=>{if(!rForm.fn||!rForm.ln||!rForm.email||!rForm.phone||!rForm.country||!rForm.pass||!rForm.biz){setRErr(t.reg.errReq);return false;}if(rForm.pass.length<8){setRErr(t.reg.errPass);return false;}setRErr("");return true;};
  const valR2=()=>{setRErr("");return true;};
  const curCode=PHONE_CODES.find(c=>c.code===rForm.phoneCode)||PHONE_CODES[0];

  const Register=(
    <div style={{background:C.bg,color:C.text,direction:t.dir,minHeight:"100vh"}}>
      <div style={{maxWidth:560,margin:"0 auto",padding:"40px 20px 60px"}}>
        <BackBtn/>
        <div style={{display:"flex",alignItems:"center",justifyContent:"center",gap:8,marginBottom:28}}>
          {[1,2,3].map(n=>(
            <div key={n} style={{display:"flex",alignItems:"center",gap:8}}>
              <div style={{display:"flex",flexDirection:"column",alignItems:"center",gap:5}}>
                <div style={{width:36,height:36,borderRadius:"50%",background:rStep>n?"linear-gradient(135deg,#00D4AA,#00b896)":rStep===n?"linear-gradient(135deg,#00D4AA,#818CF8)":C.inp,border:`2px solid ${rStep>=n?"transparent":C.inpB}`,display:"flex",alignItems:"center",justifyContent:"center",fontSize:13,fontWeight:900,color:rStep>=n?"#fff":C.muted,transition:"all .4s",boxShadow:rStep===n?"0 0 14px rgba(0,212,170,0.4)":"none"}}>
                  {rStep>n?<CheckCircle size={17} strokeWidth={2.5}/>:n}
                </div>
                <span style={{fontSize:9,fontWeight:600,color:rStep>=n?A:C.muted,whiteSpace:"nowrap"}}>{[t.reg.s1,t.reg.s2,t.reg.s3][n-1]}</span>
              </div>
              {n<3&&<div style={{width:36,height:2,borderRadius:2,background:rStep>n?A:C.inpB,transition:"background .4s",marginBottom:16}}/>}
            </div>
          ))}
        </div>
        <div style={{background:dark?"rgba(255,255,255,0.03)":C.card,border:`1px solid ${C.border}`,borderRadius:20,padding:"28px 24px",boxShadow:dark?"0 8px 40px rgba(0,0,0,0.4)":"0 8px 40px rgba(0,0,0,0.07)"}}>
          {!rDone&&(<div style={{marginBottom:20}}><h2 style={{fontSize:21,fontWeight:900,marginBottom:4,color:C.text}}>{t.reg.title}</h2><p style={{color:C.sub,fontSize:13}}>{t.reg.sub}</p></div>)}
          {rStep===1&&!rDone&&(
            <div style={{display:"flex",flexDirection:"column",gap:16}}>
              <div style={{display:"grid",gridTemplateColumns:"1fr 1fr",gap:12}}>
                {[{l:t.reg.fnL,p:t.reg.fnP,k:"fn"},{l:t.reg.lnL,p:t.reg.lnP,k:"ln"}].map(({l,p,k})=>(
                  <div key={k}><div style={{fontSize:13,fontWeight:700,marginBottom:7,color:C.text}}>{l}</div><input value={rForm[k]} onChange={e=>rf(k,e.target.value)} placeholder={p} style={bi} onFocus={e=>e.target.style.borderColor=A} onBlur={e=>e.target.style.borderColor=C.inpB}/></div>
                ))}
              </div>
              <div>
                <div style={{fontSize:13,fontWeight:700,marginBottom:7,color:C.text}}>{t.reg.phL}</div>
                <div style={{display:"flex",gap:8}}>
                  <div ref={codeRef} style={{position:"relative",flexShrink:0}}>
                    <button type="button" onClick={()=>setCodeOpen(!codeOpen)} style={{height:"100%",minHeight:42,padding:"0 10px",borderRadius:10,border:`1px solid ${codeOpen?A:C.inpB}`,background:C.inp,color:C.text,cursor:"pointer",fontSize:13,fontWeight:700,display:"flex",alignItems:"center",gap:5,whiteSpace:"nowrap",transition:"border-color .2s"}}>
                      <span style={{fontSize:16}}>{curCode.flag}</span><span>{curCode.code}</span>
                      <ChevronDown size={11} color={C.muted} style={{transform:codeOpen?"rotate(180deg)":"rotate(0)",transition:"transform .2s"}} strokeWidth={2}/>
                    </button>
                    {codeOpen&&(
                      <div style={{position:"absolute",top:"calc(100% + 6px)",left:0,width:220,maxHeight:220,overflowY:"auto",background:C.drop,border:`1px solid ${C.border}`,borderRadius:12,boxShadow:"0 8px 32px rgba(0,0,0,0.2)",zIndex:9999}}>
                        {PHONE_CODES.map((pc,i)=>(
                          <button key={i} type="button" onClick={()=>{rf("phoneCode",pc.code);setCodeOpen(false);}} style={{width:"100%",display:"flex",alignItems:"center",gap:8,padding:"9px 14px",background:rForm.phoneCode===pc.code?"rgba(0,212,170,0.10)":"transparent",border:"none",color:rForm.phoneCode===pc.code?A:C.sub,cursor:"pointer",fontSize:12,fontWeight:rForm.phoneCode===pc.code?700:400,textAlign:isRtl?"right":"left",transition:"background .15s"}}>
                            <span style={{fontSize:14}}>{pc.flag}</span><span>{pc.name}</span><span style={{marginRight:"auto",color:C.muted,fontSize:11}}>{pc.code}</span>
                          </button>
                        ))}
                      </div>
                    )}
                  </div>
                  <input type="tel" value={rForm.phone} onChange={e=>rf("phone",e.target.value)} placeholder={t.reg.phP} style={{...bi,flex:1}} onFocus={e=>e.target.style.borderColor=A} onBlur={e=>e.target.style.borderColor=C.inpB}/>
                </div>
              </div>
              <div><div style={{fontSize:13,fontWeight:700,marginBottom:7,color:C.text}}>{t.reg.bL}</div><input value={rForm.biz} onChange={e=>rf("biz",e.target.value)} placeholder={t.reg.bP} style={bi} onFocus={e=>e.target.style.borderColor=A} onBlur={e=>e.target.style.borderColor=C.inpB}/></div>
              <div>
                <div style={{fontSize:13,fontWeight:700,marginBottom:7,color:C.text}}>{t.reg.cL}</div>
                <div style={{position:"relative"}}>
                  <select value={rForm.country} onChange={e=>rf("country",e.target.value)} style={{...bi,appearance:"none",WebkitAppearance:"none",cursor:"pointer",paddingRight:isRtl?"14px":"34px",paddingLeft:isRtl?"34px":"14px"}} onFocus={e=>e.target.style.borderColor=A} onBlur={e=>e.target.style.borderColor=C.inpB}>
                    <option value="">{t.reg.cP}</option>
                    {(COUNTRIES[lang]||COUNTRIES.en).map((c,i)=><option key={i} value={c} style={{background:dark?"#1a1a3e":"#fff",color:dark?"#f1f5f9":"#0f172a"}}>{c}</option>)}
                  </select>
                  <ChevronDown size={13} color={C.muted} style={{position:"absolute",[isRtl?"left":"right"]:10,top:"50%",transform:"translateY(-50%)",pointerEvents:"none"}} strokeWidth={2}/>
                </div>
              </div>
              <div><div style={{fontSize:13,fontWeight:700,marginBottom:7,color:C.text}}>{t.reg.eL}</div><input type="email" value={rForm.email} onChange={e=>rf("email",e.target.value)} placeholder={t.reg.eP} style={bi} onFocus={e=>e.target.style.borderColor=A} onBlur={e=>e.target.style.borderColor=C.inpB}/></div>
              <div>
                <div style={{fontSize:13,fontWeight:700,marginBottom:7,color:C.text}}>{t.reg.pL}</div>
                <div style={{position:"relative"}}>
                  <input type={showP?"text":"password"} value={rForm.pass} onChange={e=>rf("pass",e.target.value)} placeholder={t.reg.pP} style={{...bi,paddingRight:isRtl?"14px":"42px",paddingLeft:isRtl?"42px":"14px"}} onFocus={e=>e.target.style.borderColor=A} onBlur={e=>e.target.style.borderColor=C.inpB}/>
                  <button type="button" onClick={()=>setShowP(!showP)} style={{position:"absolute",[isRtl?"left":"right"]:12,top:"50%",transform:"translateY(-50%)",background:"transparent",border:"none",cursor:"pointer",color:C.muted,display:"flex"}}>{showP?<EyeOff size={15} strokeWidth={1.8}/>:<Eye size={15} strokeWidth={1.8}/>}</button>
                </div>
              </div>
              <div>
                <div style={{fontSize:13,fontWeight:700,marginBottom:8,color:C.text}}>{t.reg.storeType}</div>
                <div style={{display:"flex",flexWrap:"wrap",gap:8}}>
                  {["Shopify","YouCan","WooCommerce","Other"].map(s=>(<label key={s} style={{padding:"8px 14px",borderRadius:9,background:C.inp,border:`1.5px solid ${C.inpB}`,cursor:"pointer",fontSize:13,fontWeight:600,display:"flex",alignItems:"center",gap:7,color:C.text}}><input type="checkbox" style={{accentColor:A}}/>{s}</label>))}
                </div>
              </div>
            </div>
          )}
          {rStep===2&&!rDone&&(
            <div style={{display:"flex",flexDirection:"column",gap:20}}>
              
              {/* Phone OTP */}
              <div>
                <h3 style={{fontSize:16,fontWeight:900,marginBottom:5,color:C.text,display:"flex",alignItems:"center",gap:8}}>
                  <div style={{width:28,height:28,borderRadius:"50%",background:"rgba(0,212,170,0.15)",border:"1px solid rgba(0,212,170,0.3)",display:"flex",alignItems:"center",justifyContent:"center",fontSize:12,fontWeight:900,color:A}}>1</div>
                  {lang==="ar"?"التحقق من رقم الهاتف":lang==="fr"?"Vérification du téléphone":lang==="es"?"Verificación del teléfono":lang==="tr"?"Telefon doğrulama":"Phone Verification"}
                </h3>
                <p style={{color:C.muted,fontSize:12,marginBottom:12,marginRight:36}}>{lang==="ar"?"سنرسل كود تحقق لرقم هاتفك":lang==="fr"?"Nous enverrons un code à votre téléphone":lang==="es"?"Enviaremos un código a tu teléfono":lang==="tr"?"Telefonunuza doğrulama kodu göndereceğiz":"We will send a verification code to your phone"}</p>
                <div style={{display:"flex",gap:8,marginBottom:10}}>
                  <input placeholder={lang==="ar"?"أدخل رقم هاتفك":lang==="fr"?"Votre numéro":"Your phone number"} style={{...bi,flex:1}} onFocus={e=>e.target.style.borderColor=A} onBlur={e=>e.target.style.borderColor=C.inpB}/>
                  <button style={{padding:"0 16px",borderRadius:10,background:"linear-gradient(135deg,#00D4AA,#818CF8)",border:"none",color:"#fff",fontSize:13,fontWeight:700,cursor:"pointer",whiteSpace:"nowrap"}}>
                    {lang==="ar"?"إرسال الكود":lang==="fr"?"Envoyer":"Send Code"}
                  </button>
                </div>
                <div style={{display:"flex",gap:8}}>
                  {[1,2,3,4,5,6].map(n=>(
                    <input key={n} maxLength={1} style={{...bi,textAlign:"center",fontSize:20,fontWeight:900,padding:"10px 0"}} onFocus={e=>e.target.style.borderColor=A} onBlur={e=>e.target.style.borderColor=C.inpB} onChange={e=>{if(e.target.value&&e.target.nextSibling)e.target.nextSibling.focus();}}/>
                  ))}
                </div>
              </div>

              <div style={{height:1,background:C.border}}/>

              {/* Card Verification */}
              <div>
                <h3 style={{fontSize:16,fontWeight:900,marginBottom:5,color:C.text,display:"flex",alignItems:"center",gap:8}}>
                  <div style={{width:28,height:28,borderRadius:"50%",background:"rgba(129,140,248,0.15)",border:"1px solid rgba(129,140,248,0.3)",display:"flex",alignItems:"center",justifyContent:"center",fontSize:12,fontWeight:900,color:"#818CF8"}}>2</div>
                  {lang==="ar"?"التحقق ببطاقة ائتمانية":lang==="fr"?"Vérification par carte":lang==="es"?"Verificación con tarjeta":lang==="tr"?"Kart doğrulama":"Card Verification"}
                </h3>
                <p style={{color:C.muted,fontSize:12,marginBottom:12,marginRight:36}}>{lang==="ar"?"لن يتم خصم أي مبلغ — للتحقق فقط":lang==="fr"?"Aucun montant ne sera débité — vérification uniquement":lang==="es"?"No se cobrará ningún monto — solo verificación":lang==="tr"?"Hiçbir ücret alınmayacak — sadece doğrulama":"No charge will be made — verification only"}</p>
                <div style={{display:"flex",flexDirection:"column",gap:10}}>
                  <div style={{position:"relative"}}>
                    <input placeholder="0000 0000 0000 0000" maxLength={19} style={{...bi,letterSpacing:"2px",fontFamily:"monospace"}} onFocus={e=>e.target.style.borderColor=A} onBlur={e=>e.target.style.borderColor=C.inpB}/>
                    <CreditCard size={15} color={C.muted} style={{position:"absolute",[isRtl?"left":"right"]:12,top:"50%",transform:"translateY(-50%)",pointerEvents:"none"}} strokeWidth={1.8}/>
                  </div>
                  <div style={{display:"grid",gridTemplateColumns:"1fr 1fr",gap:10}}>
                    <input placeholder="MM/YY" maxLength={5} style={{...bi,letterSpacing:"1px"}} onFocus={e=>e.target.style.borderColor=A} onBlur={e=>e.target.style.borderColor=C.inpB}/>
                    <input placeholder="CVV" type="password" maxLength={4} style={bi} onFocus={e=>e.target.style.borderColor=A} onBlur={e=>e.target.style.borderColor=C.inpB}/>
                  </div>
                  <input placeholder={lang==="ar"?"الاسم على البطاقة":"Name on card"} style={bi} onFocus={e=>e.target.style.borderColor=A} onBlur={e=>e.target.style.borderColor=C.inpB}/>
                </div>
              </div>

              <div style={{padding:"10px 14px",borderRadius:9,background:"rgba(0,212,170,0.08)",border:"1px solid rgba(0,212,170,0.22)",display:"flex",alignItems:"flex-start",gap:8}}>
                <Shield size={13} color={A} strokeWidth={2} style={{flexShrink:0,marginTop:2}}/><p style={{fontSize:12,color:C.sub,lineHeight:1.6}}>{lang==="ar"?"بياناتك محمية بتشفير SSL — لن يتم خصم أي مبلغ الآن":lang==="fr"?"Vos données sont protégées par SSL — aucun débit maintenant":lang==="es"?"Sus datos están protegidos por SSL — sin cargos ahora":lang==="tr"?"Verileriniz SSL ile korunur — şimdi ücret alınmaz":"Your data is SSL protected — no charge now"}</p>
              </div>
            </div>
          )}
          {rStep===3&&!rDone&&(
            <div style={{display:"flex",flexDirection:"column",gap:10}}>
              {t.pricing.plans.map((p,i)=>{const col=PCOLS[i];return(
                <label key={i} style={{display:"flex",alignItems:"center",gap:12,padding:"13px 15px",borderRadius:12,cursor:"pointer",background:rPlan===p.name?`${col}12`:C.inp,border:`1.5px solid ${rPlan===p.name?col:C.inpB}`,transition:"all .2s"}}>
                  <input type="radio" name="plan" checked={rPlan===p.name} onChange={()=>setRPlan(p.name)} style={{accentColor:col}}/>
                  <div style={{flex:1}}><div style={{fontWeight:800,fontSize:14,display:"flex",alignItems:"center",gap:7,color:C.text}}>{p.name}{p.popular&&<span style={{fontSize:10,background:col,color:"#fff",padding:"2px 8px",borderRadius:10,fontWeight:800}}>{t.reg.bestLabel}</span>}</div><div style={{color:C.muted,fontSize:11,marginTop:2}}>{p.features[0]}</div></div>
                  <div style={{fontWeight:900,color:col,fontSize:13}}>${p.price}/mo</div>
                </label>
              );})}
              <div style={{padding:"10px 14px",borderRadius:10,fontSize:12,background:"rgba(0,212,170,0.08)",border:"1px solid rgba(0,212,170,0.22)",color:A,fontWeight:600,display:"flex",alignItems:"center",gap:8}}><Shield size={12} strokeWidth={2}/>{t.reg.freeNote}</div>
            </div>
          )}
          {rDone&&(
            <div style={{textAlign:"center",padding:"16px 0"}}>
              <div style={{width:76,height:76,borderRadius:"50%",background:"rgba(0,212,170,0.10)",border:"2px solid #00D4AA",display:"flex",alignItems:"center",justifyContent:"center",margin:"0 auto 22px",boxShadow:"0 0 32px rgba(0,212,170,0.3)"}}><CheckCircle size={42} color="#00D4AA" strokeWidth={1.5}/></div>
              <h2 style={{fontSize:24,fontWeight:900,marginBottom:9,color:C.text}}>{t.reg.done}</h2>
              <p style={{color:C.sub,fontSize:14,lineHeight:1.7,marginBottom:28}}>{t.reg.doneSub}</p>
              <button onClick={()=>{goPage("pricing");setPView("plans");setPayDone(false);}} style={{display:"inline-flex",alignItems:"center",gap:8,padding:"13px 30px",borderRadius:12,background:"linear-gradient(135deg,#00D4AA,#818CF8)",color:"#fff",border:"none",cursor:"pointer",fontSize:14,fontWeight:800,boxShadow:"0 6px 20px rgba(0,212,170,0.35)"}}>{t.reg.choosePlan}</button>
            </div>
          )}
          {rErr&&<div style={{marginTop:14,padding:"10px 14px",borderRadius:9,background:"rgba(239,68,68,0.10)",border:"1px solid rgba(239,68,68,0.25)",color:"#EF4444",fontSize:13,fontWeight:600,display:"flex",alignItems:"center",gap:8}}><AlertCircle size={13} strokeWidth={2}/>{rErr}</div>}
          {!rDone&&(
            <div style={{display:"flex",gap:10,marginTop:20}}>
              {rStep>1&&<button onClick={()=>{setRStep(rStep-1);setRErr("");}} style={{flex:1,padding:"12px",borderRadius:11,background:"transparent",border:`1.5px solid ${C.border}`,color:C.text,fontFamily:"inherit",fontSize:14,fontWeight:700,cursor:"pointer"}}>{t.reg.prev}</button>}
              <button onClick={()=>{if(rStep===1){if(valR1())setRStep(2);}else if(rStep===2){if(valR2())setRStep(3);}else if(rStep===3)setRDone(true);}} style={{flex:2,padding:"12px",borderRadius:11,border:"none",background:"linear-gradient(135deg,#00D4AA,#818CF8)",color:"#fff",fontFamily:"inherit",fontSize:15,fontWeight:900,cursor:"pointer",boxShadow:"0 4px 14px rgba(0,212,170,0.30)"}} onMouseEnter={e=>e.currentTarget.style.transform="translateY(-2px)"} onMouseLeave={e=>e.currentTarget.style.transform="translateY(0)"}>
                {rStep<3?t.reg.next:t.reg.submit}
              </button>
            </div>
          )}
          {rStep===1&&!rDone&&(<p style={{textAlign:"center",color:C.sub,fontSize:13,marginTop:14}}>{t.reg.hasAcc}{" "}<button onClick={()=>goPage("login")} style={{background:"none",border:"none",color:A,cursor:"pointer",fontWeight:800,fontSize:13}}>{t.reg.loginLink}</button></p>)}
        </div>
      </div>
    </div>
  );

  /* ════════════ PRICING ════════════ */
  const Pricing=(
    <div style={{background:C.bg,color:C.text,direction:t.dir,minHeight:"100vh"}}>
      {pView==="plans"&&(
        <div style={{maxWidth:1100,margin:"0 auto",padding:"52px 20px 80px"}}>
          <BackBtn/>
          <div style={{textAlign:"center",marginBottom:48}}>
            <h1 style={{fontSize:"clamp(22px,4vw,46px)",fontWeight:900,marginBottom:12,color:C.text}}>{t.pricing.title}</h1>
            <p style={{color:C.sub,fontSize:16,maxWidth:500,margin:"0 auto",lineHeight:1.7}}>{t.pricing.sub}</p>
          </div>
          <div style={{display:"grid",gridTemplateColumns:"repeat(auto-fit,minmax(280px,1fr))",gap:22,alignItems:"center"}}>
            {t.pricing.plans.map((plan,i)=>{const col=PCOLS[i];return(
              <div key={plan.id} style={{background:plan.popular?`linear-gradient(145deg,${col}15,${col}08)`:C.card,border:plan.popular?`2px solid ${col}`:`1px solid ${C.border}`,borderRadius:22,padding:"1.8rem",position:"relative",transition:"transform .3s,box-shadow .3s",transform:plan.popular?"scale(1.04)":"scale(1)",boxShadow:plan.popular?`0 12px 48px ${col}25`:(dark?"none":C.cardSh)}} onMouseEnter={e=>{e.currentTarget.style.transform=plan.popular?"scale(1.07)":"scale(1.02)";}} onMouseLeave={e=>{e.currentTarget.style.transform=plan.popular?"scale(1.04)":"scale(1)";}}>
                {plan.popular&&<div style={{position:"absolute",top:-15,left:"50%",transform:"translateX(-50%)",background:col,color:"#fff",borderRadius:20,padding:"5px 18px",fontSize:12,fontWeight:800,whiteSpace:"nowrap",display:"flex",alignItems:"center",gap:6}}><Star size={11} strokeWidth={2.5}/>{t.pricing.popular}</div>}
                <div style={{fontSize:11,color:col,fontWeight:800,marginBottom:6,letterSpacing:1,textTransform:"uppercase"}}>{plan.en}</div>
                <div style={{fontSize:23,fontWeight:900,marginBottom:5,color:C.text}}>{plan.name}</div>
                <div style={{fontSize:13,color:C.sub,marginBottom:18}}>{plan.desc}</div>
                <div style={{display:"flex",alignItems:"baseline",gap:4,marginBottom:20}}>
                  <span style={{fontSize:42,fontWeight:900,color:col,lineHeight:1}}>${plan.price}</span>
                  <span style={{fontSize:13,color:C.muted}}>{t.pricing.monthly}</span>
                </div>
                <ul style={{listStyle:"none",padding:0,margin:"0 0 22px",display:"flex",flexDirection:"column",gap:9}}>
                  {plan.features.map((f,j)=>(<li key={j} style={{display:"flex",alignItems:"center",gap:9,fontSize:13}}><div style={{width:17,height:17,borderRadius:"50%",background:`${col}20`,display:"flex",alignItems:"center",justifyContent:"center",flexShrink:0}}><Check size={9} color={col} strokeWidth={3}/></div><span style={{color:C.sub}}>{f}</span></li>))}
                </ul>
                <button onClick={()=>{if(plan.cta==="contactUs"){goPage("contact");return;}setSelPlan(plan);setCard({num:"",exp:"",cvc:"",name:""});setCardErr("");setPayLoad(false);setPayDone(false);setPView("payment");}} style={{width:"100%",padding:"12px 0",borderRadius:12,background:plan.popular?col:"transparent",color:plan.popular?"#fff":col,border:plan.popular?"none":`2px solid ${col}`,fontSize:14,fontWeight:800,cursor:"pointer",transition:"opacity .2s"}} onMouseEnter={e=>e.currentTarget.style.opacity=".85"} onMouseLeave={e=>e.currentTarget.style.opacity="1"}>
                  {t.pricing[plan.cta]}
                </button>
              </div>
            );})}
          </div>
          <div style={{textAlign:"center",marginTop:22,display:"flex",alignItems:"center",justifyContent:"center",gap:7,color:C.muted,fontSize:13}}><Shield size={13} color={A} strokeWidth={2}/>{t.pricing.trialNote}</div>
        </div>
      )}
      {pView==="payment"&&!payDone&&(
        <div style={{maxWidth:900,margin:"0 auto",padding:"40px 20px 80px"}}>
          <button onClick={()=>setPView("plans")} style={{display:"inline-flex",alignItems:"center",gap:7,background:"transparent",border:`1px solid ${C.border}`,color:C.sub,cursor:"pointer",fontSize:14,fontWeight:600,marginBottom:28,padding:"8px 16px",borderRadius:9,transition:"all .2s"}} onMouseEnter={e=>{e.currentTarget.style.borderColor=A;e.currentTarget.style.color=A;}} onMouseLeave={e=>{e.currentTarget.style.borderColor=C.border;e.currentTarget.style.color=C.sub;}}>
            {isRtl?<ArrowRight size={15} strokeWidth={2}/>:<ArrowLeft size={15} strokeWidth={2}/>}{t.pricing.backBtn}
          </button>
          <div style={{display:"grid",gridTemplateColumns:"repeat(auto-fit,minmax(280px,1fr))",gap:26,alignItems:"start"}}>
            <div style={{background:dark?"rgba(255,255,255,0.04)":C.card,border:`1px solid ${C.border}`,borderRadius:20,padding:"26px 22px",boxShadow:dark?"0 8px 40px rgba(0,0,0,0.4)":"0 8px 40px rgba(0,0,0,0.07)"}}>
              <div style={{display:"flex",alignItems:"center",gap:9,marginBottom:22}}>
                <div style={{width:36,height:36,borderRadius:10,background:"rgba(0,212,170,0.12)",border:"1px solid rgba(0,212,170,0.25)",display:"flex",alignItems:"center",justifyContent:"center"}}><CreditCard size={17} color={A} strokeWidth={1.8}/></div>
                <h2 style={{fontSize:17,fontWeight:900,color:C.text}}>{t.pricing.payTitle}</h2>
              </div>
              <div style={{display:"flex",flexDirection:"column",gap:15}}>
                <div><div style={{fontSize:12,fontWeight:700,marginBottom:7,color:C.text}}>{t.pricing.cnL}</div><div style={{position:"relative"}}><input value={card.num} onChange={e=>setCard(c=>({...c,num:fmtCard(e.target.value)}))} placeholder={t.pricing.cnP} maxLength={19} style={{...bi,paddingRight:isRtl?"14px":"42px",paddingLeft:isRtl?"42px":"14px",letterSpacing:"2px",fontFamily:"monospace,'Tajawal'"}} onFocus={e=>e.target.style.borderColor=A} onBlur={e=>e.target.style.borderColor=C.inpB}/><CreditCard size={15} color={C.muted} style={{position:"absolute",[isRtl?"left":"right"]:12,top:"50%",transform:"translateY(-50%)",pointerEvents:"none"}} strokeWidth={1.8}/></div></div>
                <div style={{display:"grid",gridTemplateColumns:"1fr 1fr",gap:12}}>
                  <div><div style={{fontSize:12,fontWeight:700,marginBottom:7,color:C.text}}>{t.pricing.exL}</div><input value={card.exp} onChange={e=>setCard(c=>({...c,exp:fmtExp(e.target.value)}))} placeholder={t.pricing.exP} maxLength={5} style={{...bi,letterSpacing:"1px"}} onFocus={e=>e.target.style.borderColor=A} onBlur={e=>e.target.style.borderColor=C.inpB}/></div>
                  <div><div style={{fontSize:12,fontWeight:700,marginBottom:7,color:C.text}}>{t.pricing.cvL}</div><input value={card.cvc} onChange={e=>setCard(c=>({...c,cvc:e.target.value.replace(/\D/g,"").slice(0,4)}))} placeholder={t.pricing.cvP} type="password" maxLength={4} style={bi} onFocus={e=>e.target.style.borderColor=A} onBlur={e=>e.target.style.borderColor=C.inpB}/></div>
                </div>
                <div><div style={{fontSize:12,fontWeight:700,marginBottom:7,color:C.text}}>{t.pricing.nmL}</div><input value={card.name} onChange={e=>setCard(c=>({...c,name:e.target.value}))} placeholder={t.pricing.nmP} style={bi} onFocus={e=>e.target.style.borderColor=A} onBlur={e=>e.target.style.borderColor=C.inpB}/></div>
                <div style={{display:"flex",gap:8,flexWrap:"wrap"}}>{["VISA","Mastercard","AMEX","MADA"].map(b=>(<div key={b} style={{padding:"4px 10px",borderRadius:6,background:dark?"rgba(255,255,255,0.08)":"rgba(0,0,0,0.05)",border:`1px solid ${C.border}`,fontSize:10,fontWeight:800,color:C.muted}}>{b}</div>))}</div>
                {cardErr&&<div style={{padding:"10px 14px",borderRadius:9,background:"rgba(239,68,68,0.10)",border:"1px solid rgba(239,68,68,0.25)",color:"#EF4444",fontSize:13,fontWeight:600,display:"flex",alignItems:"center",gap:8}}><AlertCircle size={13} strokeWidth={2}/>{cardErr}</div>}
                <button onClick={()=>{const raw=card.num.replace(/\s/g,"");if(raw.length<16||!card.exp||card.cvc.length<3||!card.name){setCardErr(t.pricing.errCard);return;}setCardErr("");setPayLoad(true);setTimeout(()=>{setPayLoad(false);setPayDone(true);},2500);}} disabled={payLoad} style={{padding:"13px",borderRadius:12,border:"none",background:payLoad?"rgba(0,212,170,0.5)":"linear-gradient(135deg,#00D4AA,#818CF8)",color:"#fff",fontSize:14,fontWeight:800,cursor:payLoad?"not-allowed":"pointer",boxShadow:"0 6px 20px rgba(0,212,170,0.35)",transition:"all .2s",display:"flex",alignItems:"center",justifyContent:"center",gap:9}}>
                  {payLoad?<div style={{width:18,height:18,border:"2px solid rgba(255,255,255,0.3)",borderTopColor:"#fff",borderRadius:"50%",animation:"spin .8s linear infinite"}}/>:<><Lock size={14} strokeWidth={2.5}/>{t.pricing.payBtn}</>}
                </button>
                <div style={{display:"flex",alignItems:"center",justifyContent:"center",gap:7,color:C.muted,fontSize:12}}><Shield size={13} color={A} strokeWidth={2}/>{t.pricing.secure}</div>
              </div>
            </div>
            {selPlan&&(
              <div style={{background:dark?"rgba(255,255,255,0.03)":C.bgS,border:`1px solid ${C.border}`,borderRadius:20,padding:"22px",position:"sticky",top:90}}>
                <h3 style={{fontSize:15,fontWeight:800,marginBottom:18,color:C.text}}>{t.pricing.orderSum}</h3>
                <div style={{display:"flex",alignItems:"center",gap:11,padding:"14px",borderRadius:12,background:dark?"rgba(255,255,255,0.04)":C.card,border:`1px solid ${C.border}`,marginBottom:18}}>
                  <div style={{width:42,height:42,borderRadius:10,background:`${PCOLS[t.pricing.plans.findIndex(p=>p.id===selPlan.id)]}20`,display:"flex",alignItems:"center",justifyContent:"center",flexShrink:0}}></div>
                  <div style={{flex:1}}><div style={{fontWeight:800,fontSize:14,color:C.text}}>{selPlan.name}</div><div style={{color:C.muted,fontSize:11,marginTop:2}}>{selPlan.en} Plan</div></div>
                  <div style={{fontWeight:900,color:PCOLS[t.pricing.plans.findIndex(p=>p.id===selPlan.id)],fontSize:17}}>${selPlan.price}</div>
                </div>
                <div style={{display:"flex",flexDirection:"column",gap:9,marginBottom:16}}>
                  <div style={{display:"flex",justifyContent:"space-between",fontSize:13,color:C.sub}}><span>{t.pricing.plan}</span><span>{selPlan.name}</span></div>
                  <div style={{height:1,background:C.border}}/>
                  <div style={{display:"flex",justifyContent:"space-between",fontSize:15,fontWeight:800}}><span style={{color:C.text}}>{t.pricing.total}</span><span style={{color:PCOLS[t.pricing.plans.findIndex(p=>p.id===selPlan.id)]}}>${selPlan.price}</span></div>
                </div>
                <div style={{padding:"10px 14px",borderRadius:10,background:"rgba(0,212,170,0.08)",border:"1px solid rgba(0,212,170,0.22)",color:A,fontSize:12,fontWeight:600,display:"flex",alignItems:"center",gap:7}}><Shield size={12} strokeWidth={2}/>{t.pricing.trialNote}</div>
                <div style={{marginTop:14}}><div style={{fontSize:11,fontWeight:700,color:C.muted,marginBottom:9,textTransform:"uppercase",letterSpacing:1}}>{t.pricing.features}</div>{selPlan.features.slice(0,4).map((f,i)=>(<div key={i} style={{display:"flex",alignItems:"center",gap:7,marginBottom:7}}><Check size={11} color={A} strokeWidth={3}/><span style={{fontSize:12,color:C.sub}}>{f}</span></div>))}</div>
              </div>
            )}
          </div>
        </div>
      )}
      {payDone&&(
        <div style={{maxWidth:460,margin:"0 auto",padding:"80px 20px",textAlign:"center"}}>
          <div style={{width:84,height:84,borderRadius:"50%",background:"rgba(0,212,170,0.10)",border:"2px solid #00D4AA",display:"flex",alignItems:"center",justifyContent:"center",margin:"0 auto 26px",boxShadow:"0 0 40px rgba(0,212,170,0.3)"}}>
            <svg width="44" height="44" viewBox="0 0 44 44" fill="none"><path d="M12 22l7 7 13-13" stroke="#00D4AA" strokeWidth="3.5" strokeLinecap="round" strokeLinejoin="round"/></svg>
          </div>
          <h2 style={{fontSize:26,fontWeight:900,marginBottom:10,color:A}}>{t.pricing.success}</h2>
          <p style={{color:C.sub,fontSize:15,lineHeight:1.7,marginBottom:32}}>{t.pricing.successSub}</p>
          <button onClick={()=>goPage("home")} style={{display:"inline-flex",alignItems:"center",gap:8,padding:"13px 34px",borderRadius:12,background:"linear-gradient(135deg,#00D4AA,#818CF8)",color:"#fff",border:"none",cursor:"pointer",fontSize:14,fontWeight:800,boxShadow:"0 6px 20px rgba(0,212,170,0.35)"}}>{t.pricing.goDash}</button>
        </div>
      )}
    </div>
  );

  /* ════════════ CONTACT ════════════ */
  const Contact=(
    <div style={{background:C.bg,color:C.text,direction:t.dir,minHeight:"100vh"}}>
      <div style={{maxWidth:1000,margin:"0 auto",padding:"52px 20px 80px"}}>
        <BackBtn/>
        <div style={{textAlign:"center",marginBottom:52}}>
          <h1 style={{fontSize:"clamp(22px,4vw,46px)",fontWeight:900,marginBottom:12,color:C.text}}>{t.contact.title}</h1>
          <p style={{color:C.sub,fontSize:16,maxWidth:480,margin:"0 auto"}}>{t.contact.sub}</p>
        </div>
        <div style={{display:"grid",gridTemplateColumns:"repeat(auto-fit,minmax(280px,1fr))",gap:32,alignItems:"start"}}>
          {/* Form */}
          <div style={{background:dark?"rgba(255,255,255,0.04)":C.card,border:`1px solid ${C.border}`,borderRadius:20,padding:"28px 24px",boxShadow:dark?"0 8px 40px rgba(0,0,0,0.4)":"0 8px 40px rgba(0,0,0,0.07)"}}>
            {!contactSent?(
              <div style={{display:"flex",flexDirection:"column",gap:16}}>
                <div><div style={{fontSize:13,fontWeight:700,marginBottom:7,color:C.text}}>{t.contact.nameL}</div><input value={contactForm.name} onChange={e=>setContactForm(f=>({...f,name:e.target.value}))} placeholder={t.contact.nameP} style={bi} onFocus={e=>e.target.style.borderColor=A} onBlur={e=>e.target.style.borderColor=C.inpB}/></div>
                <div><div style={{fontSize:13,fontWeight:700,marginBottom:7,color:C.text}}>{t.contact.emailL}</div><input type="email" value={contactForm.email} onChange={e=>setContactForm(f=>({...f,email:e.target.value}))} placeholder={t.contact.emailP} style={bi} onFocus={e=>e.target.style.borderColor=A} onBlur={e=>e.target.style.borderColor=C.inpB}/></div>
                <div><div style={{fontSize:13,fontWeight:700,marginBottom:7,color:C.text}}>{t.contact.subjectL}</div><input value={contactForm.subject} onChange={e=>setContactForm(f=>({...f,subject:e.target.value}))} placeholder={t.contact.subjectP} style={bi} onFocus={e=>e.target.style.borderColor=A} onBlur={e=>e.target.style.borderColor=C.inpB}/></div>
                <div><div style={{fontSize:13,fontWeight:700,marginBottom:7,color:C.text}}>{t.contact.msgL}</div><textarea value={contactForm.msg} onChange={e=>setContactForm(f=>({...f,msg:e.target.value}))} placeholder={t.contact.msgP} rows={5} style={{...bi,resize:"vertical",minHeight:120}} onFocus={e=>e.target.style.borderColor=A} onBlur={e=>e.target.style.borderColor=C.inpB}/></div>
                <button onClick={()=>{if(!contactForm.name||!contactForm.email||!contactForm.msg)return;setContactLoad(true);setTimeout(()=>{setContactLoad(false);setContactSent(true);},1800);}} disabled={contactLoad} style={{padding:"13px",borderRadius:12,border:"none",background:contactLoad?"rgba(0,212,170,0.5)":"linear-gradient(135deg,#00D4AA,#818CF8)",color:"#fff",fontSize:15,fontWeight:800,cursor:contactLoad?"not-allowed":"pointer",display:"flex",alignItems:"center",justifyContent:"center",gap:9,boxShadow:"0 6px 20px rgba(0,212,170,0.35)"}}>
                  {contactLoad?<div style={{width:18,height:18,border:"2px solid rgba(255,255,255,0.3)",borderTopColor:"#fff",borderRadius:"50%",animation:"spin .8s linear infinite"}}/>:<><Send size={15} strokeWidth={2}/>{t.contact.send}</>}
                </button>
              </div>
            ):(
              <div style={{textAlign:"center",padding:"24px 0"}}>
                <div style={{width:72,height:72,borderRadius:"50%",background:"rgba(0,212,170,0.10)",border:"2px solid #00D4AA",display:"flex",alignItems:"center",justifyContent:"center",margin:"0 auto 20px",boxShadow:"0 0 28px rgba(0,212,170,0.3)"}}><CheckCircle size={38} color="#00D4AA" strokeWidth={1.5}/></div>
                <h3 style={{fontSize:22,fontWeight:900,marginBottom:9,color:C.text}}>{t.contact.sent}</h3>
                <p style={{color:C.sub,fontSize:14,lineHeight:1.7,marginBottom:24}}>{t.contact.sentSub}</p>
                <button onClick={()=>{setContactSent(false);setContactForm({name:"",email:"",subject:"",msg:""}); }} style={{padding:"10px 24px",borderRadius:10,background:"transparent",border:`1.5px solid ${A}`,color:A,cursor:"pointer",fontSize:14,fontWeight:700}}>{isRtl?"إرسال رسالة أخرى":"Send another message"}</button>
              </div>
            )}
          </div>
          {/* Contact info */}
          <div>
            <h3 style={{fontSize:17,fontWeight:800,marginBottom:22,color:C.text}}>{t.contact.officeTitle}</h3>
            <div style={{display:"flex",flexDirection:"column",gap:16}}>
              {[[Mail,t.contact.email,"#00D4AA"],[Phone,t.contact.phone,"#818CF8"],[Clock,t.contact.hours,"#F59E0B"]].map(([Ic,val,col],i)=>(
                <div key={i} style={{display:"flex",alignItems:"center",gap:14,padding:"14px 18px",borderRadius:14,background:dark?"rgba(255,255,255,0.04)":C.card,border:`1px solid ${C.border}`,boxShadow:C.cardSh}}>
                  <div style={{width:40,height:40,borderRadius:11,background:`${col}18`,display:"flex",alignItems:"center",justifyContent:"center",flexShrink:0}}><Ic size={18} color={col} strokeWidth={1.8}/></div>
                  <div><div style={{fontWeight:700,fontSize:14,color:C.text}}>{val}</div></div>
                </div>
              ))}
            </div>
            <div style={{marginTop:28}}>
              <h4 style={{fontSize:14,fontWeight:700,marginBottom:14,color:C.text}}>{t.contact.social}</h4>
              <div style={{display:"flex",gap:10}}>
                {[[Twitter,"#1DA1F2"],[Linkedin,"#0A66C2"],[Facebook,"#1877F2"],[Instagram,"#E4405F"],[Youtube,"#FF0000"]].map(([Ic,col],i)=>(
                  <div key={i} style={{width:38,height:38,borderRadius:9,background:C.card,border:`1px solid ${C.border}`,display:"flex",alignItems:"center",justifyContent:"center",cursor:"pointer",transition:"all .2s"}} onMouseEnter={e=>{e.currentTarget.style.borderColor=col;e.currentTarget.style.background=`${col}15`;}} onMouseLeave={e=>{e.currentTarget.style.borderColor=C.border;e.currentTarget.style.background=C.card;}}><Ic size={16} color={C.muted} strokeWidth={1.8}/></div>
                ))}
              </div>
            </div>
          </div>
        </div>
      </div>
      {Footer}
    </div>
  );

  /* ════════════ ABOUT PAGE ════════════ */
  const About=(
    <div style={{background:C.bg,color:C.text,direction:t.dir,minHeight:"100vh"}}>
      <div style={{maxWidth:900,margin:"0 auto",padding:"52px 20px 80px"}}>
        <BackBtn/>
        <h1 style={{fontSize:"clamp(24px,4vw,48px)",fontWeight:900,marginBottom:12,color:C.text}}>{t.about.title}</h1>
        <p style={{color:A,fontSize:18,fontWeight:700,marginBottom:28}}>{t.about.sub}</p>
        <p style={{color:C.sub,fontSize:17,lineHeight:1.85,marginBottom:16}}>{t.about.p1}</p>
        <p style={{color:C.sub,fontSize:17,lineHeight:1.85,marginBottom:52}}>{t.about.p2}</p>
        <div style={{display:"grid",gridTemplateColumns:"repeat(auto-fit,minmax(260px,1fr))",gap:24,marginBottom:52}}>
          {[[t.about.mission,t.about.missionText,Target,A],[t.about.vision,t.about.visionText,Star,"#818CF8"]].map(([title,body,Ic,col],i)=>(
            <div key={i} style={{background:C.card,border:`1px solid ${C.border}`,borderRadius:18,padding:"26px 22px",boxShadow:C.cardSh}}>
              <div style={{width:46,height:46,borderRadius:12,background:`${col}18`,display:"flex",alignItems:"center",justifyContent:"center",marginBottom:14}}><Ic size={22} color={col} strokeWidth={1.8}/></div>
              <h3 style={{fontWeight:800,fontSize:17,marginBottom:10,color:C.text}}>{title}</h3>
              <p style={{color:C.sub,fontSize:14,lineHeight:1.75}}>{body}</p>
            </div>
          ))}
        </div>
        <div style={{background:dark?"rgba(255,255,255,0.04)":C.card,border:`1px solid ${C.border}`,borderRadius:18,padding:"28px 24px",boxShadow:C.cardSh}}>
          <h3 style={{fontWeight:800,fontSize:17,marginBottom:18,color:C.text}}>{t.about.values}</h3>
          <div style={{display:"grid",gridTemplateColumns:"repeat(auto-fit,minmax(200px,1fr))",gap:14}}>
            {t.about.valItems.map((v,i)=>(
              <div key={i} style={{display:"flex",alignItems:"center",gap:10,padding:"12px 16px",borderRadius:12,background:dark?"rgba(0,212,170,0.06)":"rgba(0,212,170,0.05)",border:"1px solid rgba(0,212,170,0.18)"}}>
                <Check size={15} color={A} strokeWidth={3} style={{flexShrink:0}}/><span style={{color:C.sub,fontSize:14}}>{v}</span>
              </div>
            ))}
          </div>
        </div>
      </div>
      {Footer}
    </div>
  );

  /* ════════════ BLOG ════════════ */
  const Blog=(
    <div style={{background:C.bg,color:C.text,direction:t.dir,minHeight:"100vh"}}>
      <div style={{maxWidth:1100,margin:"0 auto",padding:"52px 20px 80px"}}>
        <BackBtn/>
        <div style={{textAlign:"center",marginBottom:52}}>
          <h1 style={{fontSize:"clamp(22px,4vw,46px)",fontWeight:900,marginBottom:12,color:C.text}}>{t.blog.title}</h1>
          <p style={{color:C.sub,fontSize:16}}>{t.blog.sub}</p>
        </div>
        <div style={{display:"grid",gridTemplateColumns:"repeat(auto-fit,minmax(300px,1fr))",gap:22}}>
          {t.blog.posts.map((post,i)=>(
            <div key={i} style={{background:C.card,border:`1px solid ${C.border}`,borderRadius:18,overflow:"hidden",transition:"all .3s",boxShadow:C.cardSh}} onMouseEnter={e=>{e.currentTarget.style.transform="translateY(-4px)";e.currentTarget.style.boxShadow=`0 20px 40px rgba(0,212,170,0.12)`;e.currentTarget.style.borderColor=A;}} onMouseLeave={e=>{e.currentTarget.style.transform="translateY(0)";e.currentTarget.style.boxShadow=C.cardSh;e.currentTarget.style.borderColor=C.border;}}>
              <div style={{height:6,background:"linear-gradient(135deg,#00D4AA,#818CF8)"}}/>
              <div style={{padding:"22px 20px"}}>
                <div style={{display:"flex",alignItems:"center",gap:10,marginBottom:14}}>
                  <span style={{padding:"3px 10px",borderRadius:20,background:"rgba(0,212,170,0.12)",border:"1px solid rgba(0,212,170,0.25)",color:A,fontSize:11,fontWeight:700}}>{post.cat}</span>
                  <span style={{color:C.muted,fontSize:12}}>{post.date}</span>
                  <span style={{color:C.muted,fontSize:12,marginRight:"auto"}}>{post.time}</span>
                </div>
                <h3 style={{fontWeight:800,fontSize:16,marginBottom:10,color:C.text,lineHeight:1.45}}>{post.title}</h3>
                <p style={{color:C.sub,fontSize:13,lineHeight:1.7,marginBottom:18}}>{post.desc}</p>
                <button onClick={()=>{ const art=t.blog.articles?.[i]; if(art) setSelArt(art); }} style={{display:"flex",alignItems:"center",gap:6,background:"transparent",border:"none",color:A,cursor:"pointer",fontSize:13,fontWeight:700,padding:0}} onMouseEnter={e=>e.currentTarget.style.opacity=".75"} onMouseLeave={e=>e.currentTarget.style.opacity="1"}>
                  {t.blog.readMore}{isRtl?<ArrowLeft size={14} strokeWidth={2.5}/>:<ArrowRight size={14} strokeWidth={2.5}/>}
                </button>
              </div>
            </div>
          ))}
        </div>
      </div>
      {Footer}
    </div>
  );

  /* ════════════ HELP ════════════ */
  const Help=(
    <div style={{background:C.bg,color:C.text,direction:t.dir,minHeight:"100vh"}}>
      <div style={{maxWidth:1000,margin:"0 auto",padding:"52px 20px 80px"}}>
        <BackBtn/>
        <div style={{textAlign:"center",marginBottom:52}}>
          <h1 style={{fontSize:"clamp(22px,4vw,46px)",fontWeight:900,marginBottom:12,color:C.text}}>{t.help.title}</h1>
          <p style={{color:C.sub,fontSize:16}}>{t.help.sub}</p>
        </div>
        <div style={{display:"grid",gridTemplateColumns:"repeat(auto-fit,minmax(220px,1fr))",gap:20,marginBottom:52}}>
          {t.help.categories.map((cat,i)=>(
            <div key={i} style={{background:C.card,border:`1px solid ${C.border}`,borderRadius:18,padding:"24px 20px",boxShadow:C.cardSh,transition:"all .3s"}} onMouseEnter={e=>{e.currentTarget.style.borderColor=A;e.currentTarget.style.transform="translateY(-3px)";}} onMouseLeave={e=>{e.currentTarget.style.borderColor=C.border;e.currentTarget.style.transform="translateY(0)";}}>
              <div style={{fontSize:32,marginBottom:12}}>{cat.icon}</div>
              <h3 style={{fontWeight:800,fontSize:16,marginBottom:8,color:C.text}}>{cat.title}</h3>
              <p style={{color:C.sub,fontSize:13,marginBottom:16,lineHeight:1.6}}>{cat.desc}</p>
              <ul style={{listStyle:"none",padding:0,margin:0,display:"flex",flexDirection:"column",gap:7}}>
                {cat.articles.map((a,j)=>(
                  <li key={j} style={{display:"flex",alignItems:"center",gap:8}}>
                    <div style={{width:5,height:5,borderRadius:"50%",background:A,flexShrink:0}}/>
                    <span style={{fontSize:13,color:C.sub,cursor:"pointer"}} onMouseEnter={e=>e.target.style.color=A} onMouseLeave={e=>e.target.style.color=C.sub}>{a}</span>
                  </li>
                ))}
              </ul>
            </div>
          ))}
        </div>
        <div style={{textAlign:"center",background:"linear-gradient(135deg,rgba(0,212,170,0.11),rgba(129,140,248,0.11))",border:"1px solid rgba(0,212,170,0.20)",borderRadius:22,padding:"40px 24px"}}>
          <h3 style={{fontSize:22,fontWeight:900,marginBottom:10,color:C.text}}>{t.help.contactTitle}</h3>
          <p style={{color:C.sub,fontSize:15,marginBottom:24}}>{t.help.contactSub}</p>
          <button onClick={()=>goPage("contact")} style={{padding:"13px 32px",borderRadius:12,background:"linear-gradient(135deg,#00D4AA,#818CF8)",border:"none",color:"#fff",fontSize:14,fontWeight:800,cursor:"pointer",boxShadow:"0 6px 20px rgba(0,212,170,0.35)",display:"inline-flex",alignItems:"center",gap:8}}>
            <HeadphonesIcon size={15} strokeWidth={2}/>{t.help.contactBtn}
          </button>
        </div>
      </div>
      {Footer}
    </div>
  );

  /* ════════════ TERMS / PRIVACY ════════════ */
  const LegalPage=({data})=>(
    <div style={{background:C.bg,color:C.text,direction:t.dir,minHeight:"100vh"}}>
      <div style={{maxWidth:800,margin:"0 auto",padding:"52px 20px 80px"}}>
        <BackBtn/>
        <h1 style={{fontSize:"clamp(22px,4vw,40px)",fontWeight:900,marginBottom:8,color:C.text}}>{data.title}</h1>
        <p style={{color:C.muted,fontSize:13,marginBottom:44}}>{data.updated}</p>
        <div style={{display:"flex",flexDirection:"column",gap:28}}>
          {data.sections.map((sec,i)=>(
            <div key={i} style={{background:C.card,border:`1px solid ${C.border}`,borderRadius:16,padding:"22px 20px",boxShadow:C.cardSh}}>
              <h3 style={{fontWeight:800,fontSize:16,marginBottom:10,color:C.text}}>{sec.title}</h3>
              <p style={{color:C.sub,fontSize:14,lineHeight:1.85}}>{sec.body}</p>
            </div>
          ))}
        </div>
      </div>
      {Footer}
    </div>
  );

  /* ════════════ RENDER ════════════ */
  return(
    <div style={{fontFamily:"'Tajawal','Segoe UI',sans-serif",direction:t.dir,minHeight:"100vh",background:C.bg,color:C.text,transition:"background .3s,color .3s"}}>
      <link href="https://fonts.googleapis.com/css2?family=Tajawal:wght@400;500;700;800;900&display=swap" rel="stylesheet"/>
      {selArt&&(
        <div onClick={e=>{if(e.target===e.currentTarget)setSelArt(null);}} style={{position:"fixed",inset:0,zIndex:3000,background:"rgba(0,0,0,0.75)",backdropFilter:"blur(8px)",display:"flex",alignItems:"flex-start",justifyContent:"center",padding:"40px 20px 60px",overflowY:"auto"}}>
          <div style={{width:"100%",maxWidth:780,background:dark?"#0f0f1e":"#ffffff",borderRadius:24,overflow:"hidden",boxShadow:"0 32px 80px rgba(0,0,0,0.5)",position:"relative"}}>
            
            {/* Header Bar */}
            <div style={{height:6,background:`linear-gradient(90deg,${selArt.color||"#00D4AA"},${selArt.color==="#00D4AA"?"#818CF8":selArt.color==="EF4444"?"#F59E0B":"#00D4AA"})`}}/>
            
            {/* Top Bar */}
            <div style={{display:"flex",alignItems:"center",justifyContent:"space-between",padding:"20px 32px 0"}}>
              <div style={{display:"flex",alignItems:"center",gap:10}}>
                <span style={{padding:"4px 14px",borderRadius:20,background:(selArt.color||"#00D4AA")+"18",border:"1px solid "+(selArt.color||"#00D4AA")+"30",color:selArt.color||"#00D4AA",fontSize:11,fontWeight:800,letterSpacing:1,textTransform:"uppercase"}}>{selArt.cat}</span>
                <span style={{color:C.muted,fontSize:12,display:"flex",alignItems:"center",gap:4}}>📅 {selArt.date}</span>
                <span style={{color:C.muted,fontSize:12,display:"flex",alignItems:"center",gap:4}}>⏱ {selArt.time}</span>
              </div>
              <button onClick={()=>setSelArt(null)} style={{width:32,height:32,borderRadius:"50%",background:dark?"rgba(255,255,255,0.08)":"rgba(0,0,0,0.06)",border:"none",color:C.muted,cursor:"pointer",fontSize:18,display:"flex",alignItems:"center",justifyContent:"center",transition:"all .2s"}} onMouseEnter={e=>{e.currentTarget.style.background="rgba(239,68,68,0.15)";e.currentTarget.style.color="#EF4444";}} onMouseLeave={e=>{e.currentTarget.style.background=dark?"rgba(255,255,255,0.08)":"rgba(0,0,0,0.06)";e.currentTarget.style.color=C.muted;}}>✕</button>
            </div>
            
            {/* Title */}
            <div style={{padding:"20px 32px 0"}}>
              <h1 style={{fontSize:"clamp(22px,3vw,30px)",fontWeight:900,color:C.text,lineHeight:1.3,letterSpacing:-0.5,marginBottom:16}}>{selArt.title}</h1>
              <div style={{height:2,width:60,background:selArt.color||"#00D4AA",borderRadius:2,marginBottom:28}}/>
            </div>
            
            {/* Article Body */}
            <div style={{padding:"0 32px 32px",fontFamily:"'Tajawal','Georgia',serif"}}>
              {(selArt.body||"").split("\n").map((line,i)=>{
                const isEmpty = line==="";
                const isH = line.endsWith(":") && line.length < 60 && !line.startsWith("●") && !line.startsWith("⚠") && !line.startsWith("✅") && !line.startsWith("⚡") && !line.startsWith("❌");
                const isGood = line.startsWith("✅");
                const isMed = line.startsWith("⚡");
                const isBad = line.startsWith("❌");
                const isWarn = line.startsWith("⚠️");
                const isBullet = line.startsWith("●");
                const isNum = /^\d+\./.test(line);
                
                if (isEmpty) return <div key={i} style={{height:16}}/>;
                
                if (isH) return (
                  <h3 key={i} style={{fontSize:17,fontWeight:800,color:C.text,marginTop:28,marginBottom:12,paddingBottom:8,borderBottom:"1px solid "+C.border}}>{line}</h3>
                );
                
                if (isGood||isMed||isBad||isWarn) {
                  const bg = isGood?"rgba(0,212,170,0.08)":isMed?"rgba(245,158,11,0.08)":"rgba(239,68,68,0.08)";
                  const border = isGood?"rgba(0,212,170,0.25)":isMed?"rgba(245,158,11,0.25)":"rgba(239,68,68,0.25)";
                  const col = isGood?"#00D4AA":isMed?"#F59E0B":"#EF4444";
                  return (
                    <div key={i} style={{display:"flex",alignItems:"flex-start",gap:12,padding:"10px 16px",borderRadius:10,background:bg,border:"1px solid "+border,marginBottom:8}}>
                      <span style={{fontSize:16,flexShrink:0,marginTop:1}}>{line.substring(0,2)}</span>
                      <span style={{color:col,fontSize:15,fontWeight:700,lineHeight:1.6}}>{line.substring(2).trim()}</span>
                    </div>
                  );
                }
                
                if (isBullet) return (
                  <div key={i} style={{display:"flex",alignItems:"flex-start",gap:12,marginBottom:8,paddingRight:8}}>
                    <div style={{width:6,height:6,borderRadius:"50%",background:selArt.color||"#00D4AA",flexShrink:0,marginTop:9}}/>
                    <span style={{color:C.sub,fontSize:15,lineHeight:1.75}}>{line.substring(1).trim()}</span>
                  </div>
                );
                
                if (isNum) return (
                  <div key={i} style={{display:"flex",alignItems:"flex-start",gap:12,marginBottom:10}}>
                    <div style={{width:26,height:26,borderRadius:"50%",background:(selArt.color||"#00D4AA")+"20",border:"1px solid "+(selArt.color||"#00D4AA")+"40",display:"flex",alignItems:"center",justifyContent:"center",flexShrink:0,fontSize:12,fontWeight:900,color:selArt.color||"#00D4AA"}}>{line.match(/^\d+/)[0]}</div>
                    <span style={{color:C.sub,fontSize:15,lineHeight:1.75,paddingTop:3}}>{line.replace(/^\d+\.\s*/,"")}</span>
                  </div>
                );
                
                return <p key={i} style={{color:C.sub,fontSize:16,lineHeight:1.9,marginBottom:4}}>{line}</p>;
              })}
            </div>
            
            {/* Footer CTA */}
            <div style={{padding:"20px 32px 28px",borderTop:"1px solid "+C.border,background:dark?"rgba(255,255,255,0.02)":"rgba(0,0,0,0.02)",display:"flex",justifyContent:"space-between",alignItems:"center",flexWrap:"wrap",gap:12}}>
              <div style={{color:C.muted,fontSize:13}}>UMCEM — {selArt.time}</div>
              <div style={{display:"flex",gap:10}}>
                <button onClick={()=>setSelArt(null)} style={{padding:"10px 22px",borderRadius:10,background:"transparent",border:"1.5px solid "+C.border,color:C.sub,fontSize:14,fontWeight:600,cursor:"pointer",fontFamily:"inherit",transition:"all .2s"}} onMouseEnter={e=>{e.currentTarget.style.borderColor=selArt.color||"#00D4AA";e.currentTarget.style.color=selArt.color||"#00D4AA";}} onMouseLeave={e=>{e.currentTarget.style.borderColor=C.border;e.currentTarget.style.color=C.sub;}}>{isRtl?"→":"←"} {t.nav.back}</button>
                <button onClick={()=>{setSelArt(null);goPage("register");setRStep(1);setRErr("");setRDone(false);}} style={{padding:"10px 24px",borderRadius:10,background:"linear-gradient(135deg,#00D4AA,#818CF8)",border:"none",color:"#fff",fontSize:14,fontWeight:800,cursor:"pointer",fontFamily:"inherit",boxShadow:"0 4px 16px rgba(0,212,170,0.3)",transition:"all .2s"}} onMouseEnter={e=>e.currentTarget.style.transform="translateY(-2px)"} onMouseLeave={e=>e.currentTarget.style.transform="translateY(0)"}>{t.nav.register} {isRtl?"←":"→"}</button>
              </div>
            </div>
          </div>
        </div>
      )}
      
      {scrolled&&(
        <button onClick={()=>window.scrollTo({top:0,behavior:"smooth"})} style={{position:"fixed",bottom:28,left:isRtl?"auto":"28px",right:isRtl?"28px":"auto",zIndex:500,width:44,height:44,borderRadius:"50%",background:"linear-gradient(135deg,#00D4AA,#818CF8)",border:"none",color:"#fff",cursor:"pointer",display:"flex",alignItems:"center",justifyContent:"center",boxShadow:"0 4px 16px rgba(0,212,170,0.4)",transition:"all .3s",animation:"fadeIn .3s ease"}}>
          <svg width="18" height="18" viewBox="0 0 18 18" fill="none"><path d="M9 14V4M9 4L4 9M9 4l5 5" stroke="#fff" strokeWidth="2.5" strokeLinecap="round" strokeLinejoin="round"/></svg>
        </button>
      )}
{Nav}{MM}
      <div style={{paddingTop:68}}>
        {page==="home"&&Home}
        {page==="login"&&Login}
        {page==="register"&&Register}
        {page==="pricing"&&Pricing}
        {page==="contact"&&Contact}
        {page==="about"&&About}
        {page==="blog"&&Blog}
        {page==="help"&&Help}
        {page==="terms"&&<LegalPage data={t.terms}/>}
        {page==="privacy"&&<LegalPage data={t.privacy}/>}
      </div>
      <style>{`
        html{scroll-behavior:smooth;}*{margin:0;padding:0;box-sizing:border-box;}
        ::-webkit-scrollbar{width:5px;}::-webkit-scrollbar-thumb{background:rgba(0,212,170,0.4);border-radius:3px;}
        @keyframes spin{to{transform:rotate(360deg);}}
        input::placeholder,textarea::placeholder{color:${C.ph};}
        select option{background:#0f0f2a;color:#f1f5f9;}
        .dn{display:flex!important;}.mb{display:none!important;}.ll{display:flex!important;}
        @media(max-width:768px){.dn{display:none!important;}.mb{display:flex!important;}.ll{display:none!important;}}
      `}</style>
    </div>
  );
}




