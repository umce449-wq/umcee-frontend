const T={
ar:{dir:"rtl",langName:"العربية",flag:"🇸🇦",
  nav:{about:"من نحن",services:"خدماتنا",how:"كيف نعمل",pricing:"الأسعار",faq:"الأسئلة الشائعة",login:"تسجيل الدخول",register:"إنشاء حساب",back:"رجوع",contact:"اتصل بنا",terms:"الشروط",privacy:"الخصوصية",blog:"المدونة",help:"مركز المساعدة"},
  hero:{badge:"المنصة الأولى لإدارة التجارة الإلكترونية",t1:"استقلالك التجاري",t2:"يبدأ من هنا",sub:"أدر فريقك، حلل أرباحك، وتحكم في مشروعك التجاري من أي مكان في العالم. ابدأ بـ 50 طلب مجاناً — بدون رسوم، بدون تعقيد.",cta1:"ابدأ مجاناً — 50 طلب",cta2:"شاهد كيف تعمل",s1:"تاجر نشط",s2:"رضا العملاء %",s3:"طلب تم معالجته"},
  pain:{title:"هل تعرف ما يحدث لـ 90% من التجار؟",sub:"يعملون بجد لأشهر... ثم يكتشفون الحقيقة المؤلمة",points:["يبيعون مئات الطلبات ولا يعرفون كم ربحوا فعلاً بعد الشحن والإرجاع والإعلانات","فريق العمل يشتغل بشكل عشوائي بدون خطة واضحة ونسب التأكيد تنهار","لا إحصائيات حقيقية — فقط أرقام مبيعات خادعة لا تعكس الأرباح الصافية","يريدون التوسع لأسواق جديدة لكن لا أداة تساعدهم على الإدارة عن بُعد"],solution:"UMCEM تحل هذه المشاكل كلها — في منصة واحدة"},
  features:{title:"كل ما تحتاجه في مكان واحد",sub:"UMCEM ليست مجرد أداة — هي نظام تشغيل كامل لمشروعك التجاري",items:[{title:"Simulation الأرباح",desc:"احسب ربحك الحقيقي قبل البدء — بعد الإعلانات والشحن والمرتجعات. لا مفاجآت."},{title:"إدارة الفريق الكاملة",desc:"وزّع المهام، تتبع الأداء، وأعطِ صلاحيات دقيقة لكل عضو في فريقك."},{title:"نظام التأكيد الذكي",desc:"3 أيام × 3 جلسات × 5 مكالمات. نظام مهام تلقائي يرفع نسبة التأكيد 35%."},{title:"ربط جميع المتاجر",desc:"Shopify, YouCan, WooCommerce وأي متجر آخر — طلباتك تصل تلقائياً."},{title:"إحصائيات لحظية حقيقية",desc:"أرباح صافية، نسب التحويل، أداء كل منتج — بيانات حقيقية تساعدك على القرار."},{title:"إدارة المخاطر",desc:"المنصة تنبهك تلقائياً عند الخسارة، ارتفاع الإرجاع، أو ضعف الأداء."},{title:"يعمل في كل مكان",desc:"أي سوق، أي عملة، أي لغة. UMCEM تتكيف مع أي سوق في العالم."},{title:"الشريط التحفيزي",desc:"واجهة مندوبين محفزة وواضحة — مهام يومية، نقاط، وتقارير أداء فورية."}]},
  how:{title:"كيف تبدأ في 4 خطوات",steps:[{title:"أنشئ حسابك",desc:"سجّل في دقيقتين وابدأ بـ 50 طلب مجاناً"},{title:"أضف منتجاتك",desc:"أضف منتجاتك بـ SKU وسعر الشراء والبيع وكل التفاصيل"},{title:"اربط متجرك",desc:"انسخ والصق API Key — طلباتك تظهر تلقائياً في اللحظة نفسها"},{title:"أدر وانمُ",desc:"راقب إحصائياتك، أدر فريقك، وخذ قرارات مبنية على بيانات حقيقية"}]},
  faq:{title:"الأسئلة الشائعة",items:[{q:"هل أحتاج خبرة تقنية لاستخدام UMCEM؟",a:"لا على الإطلاق. ربط متجرك يحتاج فقط نسخ ولصق API Key — لا أكواد ولا خبرة تقنية."},{q:"هل يمكنني إدارة أكثر من متجر في نفس الوقت؟",a:"نعم، تستطيع ربط Shopify وYouCan وWooCommerce وأي متجر آخر في نفس اللوحة. الطلبات تأتي من جميع متاجرك في مكان واحد."},{q:"كيف يعمل نظام Simulation الأرباح؟",a:"تدخل سعر الشراء والبيع وتكلفة الإعلانات والشحن والإرجاع — المنصة تحسب الربح الصافي وتعرض 3 سيناريوهات (أفضل/متوقع/أسوأ)."},{q:"ماذا يحدث بعد انتهاء الفترة التجريبية؟",a:"ستتلقى تنبيهاً قبل 3 أيام من انتهاء الفترة. يمكنك الاشتراك في أي خطة أو إلغاء الحساب. لا رسوم خفية."},{q:"هل تدعم المنصة لغات متعددة؟",a:"نعم، تدعم UMCEM العربية والإنجليزية والفرنسية والإسبانية والتركية. يمكنك التبديل بين اللغات بنقرة واحدة."},{q:"هل بياناتي آمنة؟",a:"بالكامل. نستخدم تشفير SSL وتخزين آمن على خوادم عالمية. بياناتك لا تُشارك مع أي طرف ثالث أبداً."},{q:"هل يمكن ربط شركات الشحن؟",a:"نعم، تدعم المنصة ربط شركات الشحن الكبرى مثل Aramex وDHL وBosta وMaystro وغيرها."},{q:"كم عدد أعضاء الفريق الذي يمكنني إضافته؟",a:"يعتمد على الخطة. الخطة الأساسية تسمح بـ 3 أعضاء، المحترف بـ 10، والأعمال بعدد غير محدود."}]},
  about:{title:"من نحن",sub:"ولدت UMCEM من معاناة حقيقية",p1:"رأينا تجاراً يعملون بجد لأشهر وسنوات، ثم يكتشفون أنهم كانوا يعملون بخسارة. المشكلة لم تكن في جهدهم — بل في غياب الأداة الصحيحة.",p2:"UMCEM خُلقت لتمنحك الاستقلال التجاري الكامل. أدر مشروعك بنفسك، بفريقك، بشروطك — من أي مكان في العالم.",mission:"مهمتنا",missionText:"تمكين كل تاجر إلكتروني من إدارة مشروعه باحترافية وكفاءة، بغض النظر عن حجم مشروعه أو البلد الذي يعمل منه.",vision:"رؤيتنا",visionText:"أن نكون المنصة الأولى في العالم العربي والعالم لإدارة التجارة الإلكترونية، ونساهم في نجاح 100,000 تاجر بحلول 2027.",values:"قيمنا",valItems:["الشفافية الكاملة في الأرباح والتكاليف","البساطة دون التضحية بالقوة","الأمان والموثوقية في كل معاملة","الدعم المستمر لكل تاجر"]},
  cta:{title:"ابدأ استقلالك التجاري اليوم",sub:"50 طلب مجاناً — لا رسوم — ابدأ الآن",btn:"ابدأ مجاناً الآن"},
  contact:{title:"اتصل بنا",sub:"نحن هنا للمساعدة. راسلنا وسنرد في أقل من 24 ساعة.",nameL:"الاسم الكامل",nameP:"أدخل اسمك",emailL:"البريد الإلكتروني",emailP:"example@domain.com",subjectL:"الموضوع",subjectP:"كيف يمكننا مساعدتك؟",msgL:"الرسالة",msgP:"اكتب رسالتك هنا...",send:"إرسال الرسالة",sending:"جارٍ الإرسال...",sent:"تم إرسال رسالتك بنجاح!",sentSub:"سنتواصل معك خلال 24 ساعة على بريدك الإلكتروني.",officeTitle:"معلومات التواصل",email:"support@UMCEM.io",phone:"+212 600 000 000",hours:"متاحون 24/7",social:"تابعنا على"},
  terms:{title:"الشروط والأحكام",updated:"آخر تحديث: يناير 2025",sections:[{title:"1. قبول الشروط",body:"باستخدامك لمنصة UMCEM، فإنك توافق على الالتزام بهذه الشروط والأحكام. إذا كنت لا توافق على أي جزء من هذه الشروط، يرجى عدم استخدام المنصة."},{title:"2. وصف الخدمة",body:"UMCEM هي منصة SaaS لإدارة عمليات التجارة الإلكترونية. توفر المنصة أدوات لإدارة الطلبات والمنتجات والفريق والإحصائيات وربط المتاجر الإلكترونية."},{title:"3. الاشتراك والدفع",body:"يتم الفوترة شهرياً مسبقاً. الأسعار شاملة الضرائب المطبقة. يمكنك إلغاء اشتراكك في أي وقت، وسيستمر الوصول حتى نهاية فترة الفوترة الحالية."},{title:"4. سياسة الاسترداد",body:"نوفر ضماناً لاسترداد المبالغ خلال 7 أيام من الاشتراك إذا لم تكن راضياً عن الخدمة. بعد هذه الفترة، لا يتم استرداد المبالغ المدفوعة."},{title:"5. أمان البيانات",body:"نلتزم بحماية بياناتك وفقاً لأعلى معايير الأمان. نستخدم تشفير SSL، ولا نشارك بياناتك مع أي طرف ثالث دون موافقتك الصريحة."},{title:"6. الملكية الفكرية",body:"جميع محتويات المنصة من تصاميم وأكواد وعلامات تجارية هي ملكية حصرية لـ UMCEM. لا يجوز نسخ أو توزيع أي محتوى دون إذن كتابي مسبق."},{title:"7. تعديل الشروط",body:"نحتفظ بحق تعديل هذه الشروط في أي وقت. سيتم إخطارك بأي تغييرات جوهرية عبر البريد الإلكتروني أو إشعار داخل المنصة."}]},
  privacy:{title:"سياسة الخصوصية",updated:"آخر تحديث: يناير 2025",sections:[{title:"1. البيانات التي نجمعها",body:"نجمع المعلومات التي تقدمها عند إنشاء الحساب (الاسم، البريد، رقم الهاتف)، وبيانات الاستخدام (الطلبات، المنتجات، الإحصائيات)، ومعلومات الجهاز والمتصفح لتحسين الأداء."},{title:"2. كيف نستخدم بياناتك",body:"نستخدم بياناتك لتقديم الخدمة وتحسينها، لإرسال إشعارات مهمة تتعلق بحسابك، لتقديم الدعم الفني، ولتحليل أنماط الاستخدام بشكل مجمّع لتطوير المنصة."},{title:"3. مشاركة البيانات",body:"لا نبيع أو نأجر أو نشارك بياناتك الشخصية مع أطراف ثالثة لأغراض تسويقية. قد نشارك بياناتك مع مزودي الخدمات الموثوقين (مثل معالجة المدفوعات) وفقاً لاتفاقيات سرية صارمة."},{title:"4. أمان البيانات",body:"نطبق أعلى معايير الأمان لحماية بياناتك، بما يشمل: تشفير SSL لجميع الاتصالات، تشفير قواعد البيانات، مراقبة مستمرة للأمان، ونسخ احتياطية منتظمة."},{title:"5. حقوقك",body:"يحق لك الوصول إلى بياناتك الشخصية، طلب تصحيحها أو حذفها، نقلها إلى منصة أخرى، أو تقييد معالجتها. للاستفادة من هذه الحقوق، تواصل مع: privacy@UMCEM.io"},{title:"6. ملفات تعريف الارتباط",body:"نستخدم ملفات تعريف الارتباط لتحسين تجربتك، تذكر تفضيلاتك، وتحليل حركة الموقع. يمكنك إدارة هذه الملفات من إعدادات متصفحك."},{title:"7. التواصل",body:"لأي استفسارات تتعلق بالخصوصية، تواصل معنا: privacy@UMCEM.io"}]},
  help:{title:"مركز المساعدة",sub:"كل ما تحتاج لمعرفته عن UMCEM في مكان واحد",categories:[{icon:"🚀",title:"البدء السريع",desc:"كيفية إنشاء حسابك وإعداد متجرك خلال دقائق",articles:["إنشاء حساب جديد","ربط متجر Shopify","ربط متجر YouCan","ربط متجر WooCommerce","إضافة أول منتج"]},{icon:"👥",title:"إدارة الفريق",desc:"كل ما يتعلق بإضافة الفريق وتحديد الصلاحيات",articles:["إضافة مندوب مبيعات","تحديد الصلاحيات","متابعة أداء الفريق","توزيع المهام تلقائياً","الشريط التحفيزي"]},{icon:"📊",title:"الإحصائيات والتقارير",desc:"كيفية قراءة وتحليل بيانات مشروعك",articles:["فهم لوحة الإحصائيات","Simulation الأرباح","تقارير PDF","مقارنة الفترات الزمنية","تحليل أداء المنتجات"]},{icon:"💳",title:"الاشتراك والفواتير",desc:"كل ما يتعلق بالدفع والاشتراكات",articles:["تغيير خطة الاشتراك","تحديث بيانات البطاقة","تنزيل الفواتير","إلغاء الاشتراك","استرداد المبالغ"]}],contactTitle:"لم تجد ما تبحث عنه؟",contactSub:"فريقنا متاح 24/7 للمساعدة",contactBtn:"تواصل مع الدعم"},
  blog:{title:"المدونة",sub:"أحدث المقالات والنصائح لنجاح تجارتك الإلكترونية",posts:[{cat:"نصائح",date:"15 يناير 2025",title:"كيف ترفع نسبة تأكيد طلباتك إلى 80%؟",desc:"دليل شامل لاستراتيجيات التأكيد الذكي وكيف يمكن لنظام المهام في UMCEM أن يحدث فرقاً كبيراً في نتائجك.",time:"5 دقائق"},{cat:"تحليلات",date:"10 يناير 2025",title:"لماذا 90% من تجار الإنترنت يعملون بخسارة؟",desc:"دراسة تحليلية لأسباب فشل التجار وكيف يمكن للإحصائيات الصحيحة أن تنقذ مشروعك.",time:"8 دقائق"},{cat:"تقنية",date:"5 يناير 2025",title:"ربط Shopify مع UMCEM: دليل خطوة بخطوة",desc:"كيفية ربط متجرك على Shopify مع UMCEM في أقل من 5 دقائق والاستفادة من المزامنة التلقائية.",time:"4 دقائق"},{cat:"استراتيجية",date:"1 يناير 2025",title:"بناء فريق مبيعات ناجح للتجارة الإلكترونية",desc:"كيف تختار وتدرب وتحفز فريق مبيعاتك باستخدام أدوات UMCEM لتحقيق أقصى النتائج.",time:"6 دقائق"},{cat:"نصائح",date:"28 ديسمبر 2024",title:"Simulation الأرباح: احسب ربحك قبل البدء",desc:"كيف تستخدم أداة Simulation في UMCEM لتقييم جدوى أي منتج قبل البدء في بيعه.",time:"5 دقائق"},{cat:"تقنية",date:"20 ديسمبر 2024",title:"نظام إدارة المخاطر في التجارة الإلكترونية",desc:"كيف تحمي مشروعك من الخسائر باستخدام أدوات تحليل المخاطر والتنبيهات التلقائية.",time:"7 دقائق"}],readMore:"اقرأ المقال",articles:[{id:1,cat:"نصائح",color:"#00D4AA",date:"15 يناير 2025",time:"5 دقائق",title:"كيف ترفع نسبة تأكيد طلباتك إلى 80%؟",desc:"دليل نفسي واستراتيجي مثبت لرفع نسبة تأكيد طلباتك وتحويل المترددين إلى عملاء حقيقيين.",body:"أنت تدفع للإعلانات. فريقك يتصل. الطلبات تأتي.\nثم تفتح تقرير نهاية الشهر وتكتشف أن 40% من طلباتك اختفت.\n\nهذا ليس فشلاً. هذا غياب نظام.\n\nالسيكولوجيا وراء الإلغاء:\nكل ساعة تمر بدون اتصال تزيد احتمال الإلغاء 15%. العميل يطلب بحماس ثم يبرد. من يتصل أولاً يربح.\n\nالنظام الذي يغير النتائج:\n\nاليوم الأول:\n● محاولة صباحية (8-10 صباحاً)\n● محاولة ظهرية (12-2 مساءً)\n● محاولة مسائية (6-8 مساءً)\n\nاليوم الثاني:\n● محاولتان مع رسالة SMS تذكيرية\n\nاليوم الثالث:\n● محاولة أخيرة مع عرض خاص للمتردد\n\nالنتائج الحقيقية:\n✅ نسبة التأكيد من 43% إلى 79% في 30 يوماً\n✅ توفير 3 ساعات يومياً\n✅ انخفاض شكاوى العملاء 60%\n\nUMCEM يعطيك هذا النظام جاهزاً من اليوم الأول.\n50 طلب مجاناً. بدون رسوم."},{id:2,cat:"تحليلات",color:"#EF4444",date:"10 يناير 2025",time:"8 دقائق",title:"لماذا 90% من تجار الإنترنت يعملون بخسارة بدون أن يعلموا؟",desc:"الحقيقة المؤلمة التي يكشفها الحساب الصحيح وكيف تعرف إن كنت تربح فعلاً.",body:"هذا المقال سيزعجك.\nلكنه قد ينقذ مشروعك.\n\nسؤال واحد: هل تعرف كم ربحت الشهر الماضي بعد كل التكاليف؟\n\nالحساب الذي يصدم الجميع:\nتاجر يبيع 400 طلب بسعر 150 $\nالمبيعات = 60,000 $\n\n● تكلفة المنتج (45 × 400) = 18,000\n● تكلفة الشحن (22 × 400) = 8,800\n● مرتجعات 25% = 6,700\n● تكلفة الإعلانات = 16,000\n● رواتب الفريق = 9,000\n● تكاليف أخرى = 2,500\n\nمجموع التكاليف = 61,000 $\n❌ الخسارة الصافية = 1,000 $ شهرياً!\n\nهذا التاجر يعمل بجد كل يوم ويعتقد أنه ناجح.\n\nأداة Simulation في UMCEM تحسب لك الربح الصافي الحقيقي قبل أن تبيع طلباً واحداً.\n\nالقاعدة الذهبية:\nلا تبيع منتجاً واحداً قبل أن تعرف رقمك الحقيقي."},{id:3,cat:"تقنية",color:"#818CF8",date:"5 يناير 2025",time:"4 دقائق",title:"ربط Shopify مع UMCEM: من الفوضى إلى النظام في 5 دقائق",desc:"دليل تقني خطوة بخطوة لربط متجرك والاستفادة من المزامنة التلقائية الكاملة.",body:"صف يومك بدون نظام:\nالساعة 8 - تفتح Shopify\nالساعة 8:15 - تنسخ طلبات إلى Excel\nالساعة 8:45 - ترسل لفريقك عبر WhatsApp\nالساعة 9:30 - مندوب يسألك عن عنوان نسيت إرساله\nالساعة 11:00 - تكتشف طلباً منسياً من أمس\n\nهذا عقاب يومي تدفع ثمنه كل ساعة.\n\nخطوات الربط (5 دقائق):\n1. Shopify ثم Settings ثم Apps and sales channels\n2. اضغط Develop apps ثم Create an app\n3. سمّه UMCEM وفعّل Orders read و Products read\n4. Install app وانسخ الـ Admin API access token\n5. UMCEM ثم الإعدادات ثم المتاجر ثم إضافة متجر\n6. الصق الـ token واحفظ\n\n✅ توفير 2-3 ساعات يومياً\n✅ لا طلبات منسية أبداً\n✅ فريقك يعمل بنظام واضح"},{id:4,cat:"استراتيجية",color:"#F59E0B",date:"1 يناير 2025",time:"6 دقائق",title:"فريق مبيعات بلا رقابة = مشروع ينزف أموالاً كل يوم",desc:"كيف تكتشف المندوب الضعيف قبل أن يكلفك آلاف الدراهم.",body:"سؤال مباشر:\nهل تعرف الآن كم مكالمة أجرى كل مندوب في فريقك اليوم؟\n\nإذا كانت إجابتك لا — أنت تخسر أموالاً الآن.\n\nالحقيقة القاسية:\nالمندوب بدون نظام يعمل بكفاءة 40% فقط. 60% من وقته يضيع.\nإذا كان لديك 5 مندوبين فأنت تدفع مقابل عمل 2 فقط.\n\nما يتغير مع UMCEM:\n\nللمندوب:\n● يرى مهامه اليومية بأولويات واضحة\n● يرى ترتيبه بين زملائه في الوقت الفعلي\n\nللمدير:\n● لوحة أداء لحظية لكل مندوب بالاسم\n● عدد المكالمات ونسبة التأكيد\n● تنبيه فوري عند انخفاض الأداء\n● تقرير يومي على هاتفك\n\n✅ نسبة التأكيد من 51% إلى 76%\n✅ المبيعات ارتفعت 43% بنفس الفريق"},{id:5,cat:"نصائح",color:"#00D4AA",date:"28 ديسمبر 2024",time:"5 دقائق",title:"Simulation الأرباح: لا تبيع منتجاً واحداً قبل أن تقرأ هذا",desc:"كيف تستخدم علم الأرقام لا الحظ في اختيار منتجاتك وضمان الربح.",body:"كم تاجراً بدأ بحماس ثم وجد حسابه فارغاً في نهاية الشهر؟\n\nالسبب دائماً واحد: بدأوا يبيعون قبل أن يحسبوا.\n\nمثال حقيقي - ساعة ذكية:\n● شراء: 85 $ / بيع: 220 / شحن: 25 / إعلانات: 42 / إرجاع: 20%\n\nبدون Simulation يرى التاجر: 220 - 85 = 135 $ ربح!\n\nمع Simulation يرى الحقيقة:\n✅ السيناريو الأفضل (80% تأكيد): ربح 43 $ لكل طلب\n⚡ السيناريو المتوقع (60% تأكيد): ربح 24 $ لكل طلب\n❌ السيناريو الأسوأ (40% تأكيد): خسارة 12 $ لكل طلب\n\nالقاعدة: لا تطلق حملة واحدة قبل أن يقول لك الـ Simulation هذا رابح."},{id:6,cat:"تقنية",color:"#EF4444",date:"20 ديسمبر 2024",time:"7 دقائق",title:"إدارة المخاطر: اعرف قبل فوات الأوان وأنقذ رأس مالك",desc:"النظام الذي يحمي مشروعك من الخسائر الصامتة ويعطيك إنذاراً مبكراً.",body:"هناك نوع من الخسارة أخطر من الخسارة الواضحة.\nإنها الخسارة الصامتة التي تنزف ببطء حتى تفاجأ بالنهاية.\n\nقصة حقيقية:\nتاجر لاحظ ارتفاعاً في الطلبات وفرح.\nلكنه لم يلاحظ أن نسبة الإرجاع ارتفعت من 17% إلى 39%.\nفي يناير فتح حسابه البنكي — كان قد خسر 34,000 $ في 3 أشهر.\n\nكيف تحميك UMCEM؟\n\nتنبيهات فورية عند:\n⚠️ نسبة الإرجاع تتجاوز حدك المحدد\n⚠️ أي منتج يدخل منطقة الخسارة\n⚠️ نسبة التأكيد تنخفض عن هدفك\n⚠️ تكلفة الإعلان ترتفع بدون نتائج\n⚠️ المخزون يقترب من النفاد\n\nطرق وصول التنبيهات:\n● إشعار فوري في لوحة التحكم\n● SMS على هاتفك\n● بريد إلكتروني تفصيلي\n\nUMCEM يجعلك دائماً أول من يعرف."}]},
  login:{title:"مرحباً بعودتك",sub:"سجّل دخولك لمتابعة مشروعك",eL:"البريد الإلكتروني",eP:"example@domain.com",pL:"كلمة المرور",pP:"أدخل كلمة المرور",forgot:"نسيت كلمة المرور؟",btn:"تسجيل الدخول",noAcc:"ليس عندك حساب؟",regLink:"أنشئ حساباً مجاناً",brand:"أدر فريقك وحلّل أرباحك من أي مكان في العالم"},
  reg:{title:"أنشئ حسابك",sub:"ابدأ رحلتك نحو الاستقلال التجاري",s1:"معلوماتك الشخصية",s2:"التحقق من الهاتف والبطاقة",s3:"اختر خطتك",fnL:"الاسم الأول",fnP:"مثال: محمد",lnL:"الاسم الأخير",lnP:"مثال: العلوي",eL:"البريد الإلكتروني",eP:"example@domain.com",phL:"رقم الهاتف",phP:"أدخل رقم هاتفك",codeL:"كود الدولة",cL:"الدولة",cP:"— اختر دولتك —",pL:"كلمة المرور",pP:"8 أحرف على الأقل",bL:"اسم مشروعك التجاري",bP:"مثال: متجر الإلكترونيات",storeType:"نوع متجرك الإلكتروني",next:"التالي",prev:"السابق",submit:"ابدأ مجاناً",hasAcc:"عندك حساب؟",loginLink:"سجّل دخولك",docTitle:"التحقق من الهوية",docSub:"ارفع إحدى الوثائق التالية (إلزامي)",idCard:"بطاقة الهوية الوطنية",pp:"جواز السفر",front:"الوجه الأمامي",back:"الوجه الخلفي",uploadHint:"JPG أو PNG أو PDF — الحجم الأقصى 5MB",secNote:"وثائقك محمية بتشفير SSL ولا تُشارك مع أي طرف ثالث",done:"تم إنشاء حسابك!",doneSub:"سيتم مراجعة وثائقك خلال 24 ساعة. ستصلك رسالة تأكيد على بريدك الإلكتروني.",choosePlan:"اختر خطتك الآن",errReq:"يرجى تعبئة جميع الحقول المطلوبة",errPass:"كلمة المرور يجب أن تكون 8 أحرف على الأقل",errDoc:"يرجى رفع وثيقة هوية صالحة",bestLabel:"الأفضل",chooseFile:"انقر للرفع",freeNote:"ستبدأ بـ 50 طلب مجاناً — لا رسوم الآن"},
  pricing:{title:"اختر خطتك",sub:"50 طلب مجاناً — لا رسوم مخفية — إلغاء في أي وقت",popular:"الأكثر شعبية",monthly:"/شهرياً",trialNote:"50 طلب مجاناً — لن تُحاسب الآن",payTitle:"إتمام الاشتراك",cnL:"رقم البطاقة",cnP:"0000 0000 0000 0000",exL:"تاريخ الانتهاء",exP:"MM/YY",cvL:"رمز الأمان",cvP:"•••",nmL:"الاسم على البطاقة",nmP:"الاسم الكامل كما في البطاقة",payBtn:"ادفع الآن",backBtn:"رجوع",secure:"دفع آمن بتشفير 256-bit SSL",orderSum:"ملخص الطلب",plan:"الخطة",total:"الإجمالي",success:"تم الدفع بنجاح!",successSub:"مرحباً بك في UMCEM. ستصلك رسالة تأكيد على بريدك الإلكتروني.",goDash:"اذهب للوحة التحكم",errCard:"يرجى إدخال بيانات البطاقة كاملة",features:"المميزات",startNow:"ابدأ الآن",startFree:"ابدأ مجاناً",contactUs:"تواصل معنا",
