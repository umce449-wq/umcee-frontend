en:{dir:"ltr",langName:"English",flag:"🇬🇧",
  nav:{about:"About",services:"Services",how:"How It Works",pricing:"Pricing",faq:"FAQ",login:"Login",register:"Sign Up",back:"Back",contact:"Contact",terms:"Terms",privacy:"Privacy",blog:"Blog",help:"Help Center"},
  hero:{badge:"The #1 E-Commerce Management Platform",t1:"Your Business Independence",t2:"Starts Here",sub:"Manage your team, analyze your profits, and control your e-commerce business from anywhere in the world. Start with 50 free orders — no fees, no complexity.",cta1:"Start Free — 50 Orders",cta2:"See How It Works",s1:"Active Merchants",s2:"Customer Satisfaction %",s3:"Orders Processed"},
  pain:{title:"Do You Know What Happens to 90% of Merchants?",sub:"They work hard for months... then discover the painful truth",points:["They sell hundreds of orders but don't know their real profit after shipping, returns, and ads","The team works randomly without a clear plan and confirmation rates collapse","No real analytics — just misleading sales numbers that don't reflect net profit","They want to expand to new markets but have no tool to manage remotely"],solution:"UMCEM solves all these problems — in one platform"},
  features:{title:"Everything You Need in One Place",sub:"UMCEM is not just a tool — it's a complete operating system for your business",items:[{title:"Profit Simulation",desc:"Calculate your real profit before you start — after ads, shipping, and returns. No surprises."},{title:"Full Team Management",desc:"Assign tasks, track performance, and give precise permissions to each team member."},{title:"Smart Confirmation System",desc:"3 days × 3 sessions × 5 calls. Automatic task system that raises confirmation rate by 35%."},{title:"Connect All Stores",desc:"Shopify, YouCan, WooCommerce and any other store — your orders arrive automatically."},{title:"Real-Time Analytics",desc:"Net profits, conversion rates, product performance — real data to help you decide."},{title:"Risk Management",desc:"The platform automatically alerts you of losses, rising returns, or weak performance."},{title:"Works Everywhere",desc:"Any market, any currency, any language. UMCEM adapts to any market in the world."},{title:"Motivation Bar",desc:"Motivating and clear agent interface — daily tasks, points, and instant performance reports."}]},
  how:{title:"Start in 4 Steps",steps:[{title:"Create Your Account",desc:"Sign up in 2 minutes and start with 50 free orders"},{title:"Add Your Products",desc:"Add your products with SKU, purchase price, sale price, and all details"},{title:"Connect Your Store",desc:"Copy and paste API Key — your orders appear automatically in real-time"},{title:"Manage & Grow",desc:"Monitor your analytics, manage your team, and make decisions based on real data"}]},
  faq:{title:"Frequently Asked Questions",items:[{q:"Do I need technical experience to use UMCEM?",a:"Not at all. Connecting your store only requires copying and pasting an API Key — no code or technical experience needed."},{q:"Can I manage more than one store at the same time?",a:"Yes, you can connect Shopify, YouCan, WooCommerce and any other store in the same dashboard. Orders come from all your stores in one place."},{q:"How does the Profit Simulation system work?",a:"You enter purchase price, sale price, ad costs, shipping, and returns — the platform calculates your real net profit and shows 3 scenarios (best/expected/worst)."},{q:"What happens after the free trial ends?",a:"You'll receive a notification 3 days before it ends. You can subscribe to any plan or cancel your account. No hidden fees."},{q:"Does the platform support multiple languages?",a:"Yes, UMCEM supports Arabic, English, French, Spanish, and Turkish. You can switch between languages with one click."},{q:"Is my data safe?",a:"Completely. We use SSL encryption and secure storage on global servers. Your data is never shared with any third party."},{q:"Can shipping companies be connected?",a:"Yes, the platform supports connecting major shipping companies like Aramex, DHL, Bosta, Maystro and others."},{q:"How many team members can I add?",a:"It depends on the plan. The Basic plan allows 3 members, Pro allows 10, and Business allows unlimited members."}]},
  about:{title:"About Us",sub:"UMCEM Was Born from Real Struggle",p1:"We saw merchants working hard for months and years, then discovering they were operating at a loss. The problem wasn't their effort — it was the absence of the right tool.",p2:"UMCEM was created to give you complete business independence. Manage your business yourself, with your team, on your terms — from anywhere in the world.",mission:"Our Mission",missionText:"To empower every e-commerce merchant to manage their business professionally and efficiently, regardless of their project size or country.",vision:"Our Vision",visionText:"To be the #1 platform in the Arab world and globally for e-commerce management, contributing to the success of 100,000 merchants by 2027.",values:"Our Values",valItems:["Full transparency in profits and costs","Simplicity without sacrificing power","Security and reliability in every transaction","Continuous support for every merchant"]},
  cta:{title:"Start Your Business Independence Today",sub:"50 orders free — no hidden fees — cancel anytime",btn:"Start Free Now"},
  contact:{title:"Contact Us",sub:"We're here to help. Message us and we'll respond within 24 hours.",nameL:"Full Name",nameP:"Enter your name",emailL:"Email Address",emailP:"example@domain.com",subjectL:"Subject",subjectP:"How can we help you?",msgL:"Message",msgP:"Write your message here...",send:"Send Message",sending:"Sending...",sent:"Your message was sent successfully!",sentSub:"We'll get back to you within 24 hours at your email address.",officeTitle:"Contact Information",email:"support@UMCEM.io",phone:"+212 600 000 000",hours:"Available 24/7",social:"Follow Us"},
  terms:{title:"Terms & Conditions",updated:"Last updated: January 2025",sections:[{title:"1. Acceptance of Terms",body:"By using UMCEM platform, you agree to be bound by these Terms and Conditions. If you do not agree to any part of these terms, please do not use the platform."},{title:"2. Service Description",body:"UMCEM is a SaaS platform for managing e-commerce operations. The platform provides tools for managing orders, products, teams, analytics, and connecting online stores."},{title:"3. Subscription and Payment",body:"Billing is done monthly in advance. Prices include applicable taxes. You can cancel your subscription at any time, and access will continue until the end of the current billing period."},{title:"4. Refund Policy",body:"We provide a money-back guarantee within 7 days of subscription if you are not satisfied with the service. After this period, paid amounts are not refunded."},{title:"5. Data Security",body:"We are committed to protecting your data according to the highest security standards. We use SSL encryption and do not share your data with any third party without your explicit consent."},{title:"6. Intellectual Property",body:"All platform content including designs, code, and trademarks are the exclusive property of UMCEM. No content may be copied or distributed without prior written permission."},{title:"7. Modification of Terms",body:"We reserve the right to modify these terms at any time. You will be notified of any material changes via email or notification within the platform."}]},
  privacy:{title:"Privacy Policy",updated:"Last updated: January 2025",sections:[{title:"1. Data We Collect",body:"We collect information you provide when creating an account (name, email, phone number), usage data (orders, products, analytics), and device and browser information to improve performance."},{title:"2. How We Use Your Data",body:"We use your data to provide and improve the service, send important notifications related to your account, provide technical support, and analyze usage patterns in aggregate to develop the platform."},{title:"3. Data Sharing",body:"We do not sell, rent, or share your personal data with third parties for marketing purposes. We may share your data with trusted service providers (such as payment processing) under strict confidentiality agreements."},{title:"4. Data Security",body:"We apply the highest security standards to protect your data, including: SSL encryption for all communications, database encryption, continuous security monitoring, and regular backups."},{title:"5. Your Rights",body:"You have the right to access your personal data, request its correction or deletion, transfer it to another platform, or restrict its processing. To exercise these rights, contact: privacy@UMCEM.io"},{title:"6. Cookies",body:"We use cookies to improve your experience, remember your preferences, and analyze site traffic. You can manage these files from your browser settings."},{title:"7. Contact",body:"For any privacy-related inquiries, contact us: privacy@UMCEM.io"}]},
  help:{title:"Help Center",sub:"Everything you need to know about UMCEM in one place",categories:[{icon:"🚀",title:"Quick Start",desc:"How to create your account and set up your store in minutes",articles:["Create a new account","Connect Shopify store","Connect YouCan store","Connect WooCommerce store","Add your first product"]},{icon:"👥",title:"Team Management",desc:"Everything about adding team members and setting permissions",articles:["Add a sales agent","Set permissions","Track team performance","Auto-distribute tasks","Motivation bar"]},{icon:"📊",title:"Analytics & Reports",desc:"How to read and analyze your business data",articles:["Understanding the analytics dashboard","Profit Simulation","PDF reports","Comparing time periods","Product performance analysis"]},{icon:"💳",title:"Subscription & Billing",desc:"Everything related to payments and subscriptions",articles:["Change subscription plan","Update card details","Download invoices","Cancel subscription","Request refund"]}],contactTitle:"Didn't find what you're looking for?",contactSub:"Our team is available 24/7 to help",contactBtn:"Contact Support"},
  blog:{title:"Blog",sub:"Latest articles and tips for your e-commerce success",posts:[{cat:"Tips",date:"January 15, 2025",title:"How to Raise Your Order Confirmation Rate to 80%?",desc:"A comprehensive guide to smart confirmation strategies and how UMCEM's task system can make a big difference in your results.",time:"5 min"},{cat:"Analytics",date:"January 10, 2025",title:"Why 90% of Online Merchants Operate at a Loss?",desc:"An analytical study of the reasons merchants fail and how the right analytics can save your business.",time:"8 min"},{cat:"Tech",date:"January 5, 2025",title:"Connecting Shopify with UMCEM: Step-by-Step Guide",desc:"How to connect your Shopify store with UMCEM in less than 5 minutes and take advantage of automatic synchronization.",time:"4 min"},{cat:"Strategy",date:"January 1, 2025",title:"Building a Successful E-Commerce Sales Team",desc:"How to choose, train, and motivate your sales team using UMCEM tools to achieve maximum results.",time:"6 min"},{cat:"Tips",date:"December 28, 2024",title:"Profit Simulation: Calculate Your Profit Before You Start",desc:"How to use the Simulation tool in UMCEM to evaluate the viability of any product before starting to sell it.",time:"5 min"},{cat:"Tech",date:"December 20, 2024",title:"Risk Management System in E-Commerce",desc:"How to protect your business from losses using risk analysis tools and automatic alerts.",time:"7 min"}],readMore:"Read Article",
articles:[{id:1,cat:"Tips",color:"#00D4AA",date:"January 15, 2025",time:"5 min read",title:"How to Raise Your Order Confirmation Rate to 80%?",desc:"A proven psychological and strategic guide to raising your confirmation rate.",body:"You spend on ads. Your team calls. Orders come in.\nThen you open your end-of-month report and discover that 40% of your orders have vanished.\n\nThis is not failure. This is the absence of a system.\n\nThe Psychology Behind Cancellations:\nEvery hour that passes without contact increases cancellation probability by 15%. The customer orders with enthusiasm then cools down. Whoever calls first wins.\n\nThe System That Changes Results:\n\nDay One:\n● Morning attempt (8-10 AM)\n● Midday attempt (12-2 PM)\n● Evening attempt (6-8 PM)\n\nDay Two:\n● Two attempts with an SMS reminder between them\n\nDay Three:\n● Final attempt with a special offer for the hesitant customer\n\nReal Results:\n✅ Confirmation rate from 43% to 79% in 30 days\n✅ Saving 3 hours daily\n✅ Customer complaints dropped 60%\n\nUMCEM gives you this system ready from day one.\n50 orders free. No fees."},{id:2,cat:"Analytics",color:"#EF4444",date:"January 10, 2025",time:"8 min read",title:"Why 90% of Online Merchants Operate at a Loss Without Knowing It?",desc:"The painful truth revealed by correct accounting and how to know if you are actually profiting.",body:"This article will disturb you.\nBut it might save your business.\n\nOne question: Do you know exactly how much you profited last month after all costs?\n\nThe Calculation That Shocks Everyone:\nA merchant selling 400 orders at $150 each\nTotal sales = $60,000\n\n● Product cost = $18,000\n● Shipping cost = $8,800\n● Returns 25% = $6,700\n● Ad costs = $16,000\n● Team salaries = $9,000\n● Other costs = $2,500\n\nTotal costs = $61,000\n❌ Net loss = $1,000 per month!\n\nUMCEM Simulation calculates your real net profit before you sell a single order.\n\nNever sell a single product before you know your real number."},{id:3,cat:"Tech",color:"#818CF8",date:"January 5, 2025",time:"4 min read",title:"Connecting Shopify with UMCEM: From Chaos to Order in 5 Minutes",desc:"A step-by-step technical guide to connecting your store and benefiting from full automatic synchronization.",body:"Your day without a system:\n8:00 AM - Open Shopify\n8:15 AM - Copy orders manually to Excel\n8:45 AM - Send to your team via WhatsApp\n9:30 AM - An agent asks about an address you forgot\n11:00 AM - You discover a forgotten order from yesterday\n\nConnection Steps (5 minutes):\n1. Shopify then Settings then Apps and sales channels\n2. Click Develop apps then Create an app\n3. Name it UMCEM and enable Orders read and Products read\n4. Install app and copy the Admin API access token\n5. UMCEM then Settings then Stores then Add Store\n6. Paste the token and save\n\n✅ Saving 2-3 hours daily\n✅ No forgotten orders ever\n✅ Your team works with a clear system"},{id:4,cat:"Strategy",color:"#F59E0B",date:"January 1, 2025",time:"6 min read",title:"A Sales Team Without Supervision = A Business Bleeding Money Every Day",desc:"How to discover the weak agent before they cost you thousands.",body:"Do you know right now how many calls each agent made today?\n\nIf your answer is no you are losing money right now.\n\nThe Hard Truth:\nAn agent without a system works at only 40% efficiency. 60% of their time is wasted.\n\nWhat Changes with UMCEM:\n\nFor the agent:\n● Sees daily tasks with clear priorities\n● Sees their ranking among colleagues in real time\n\nFor the manager:\n● Real-time performance dashboard for each agent\n● Call count and confirmation rate\n● Instant alert when performance drops\n● Daily report sent to your phone\n\n✅ Confirmation rate from 51% to 76%\n✅ Sales up 43% with the same team"},{id:5,cat:"Tips",color:"#00D4AA",date:"December 28, 2024",time:"5 min read",title:"Profit Simulation: Never Sell a Single Product Before Reading This",desc:"How to use the science of numbers not luck to choose your products.",body:"How many merchants started with excitement then found their account empty at month end?\n\nThe reason is always the same: they started selling before calculating.\n\nReal Example - Smart Watch:\n● Purchase: $85 / Sale: $220 / Shipping: $25 / Ads: $42 / Returns: 20%\n\nWithout Simulation: 220 - 85 = $135 profit!\n\nWith Simulation:\n✅ Best case (80% confirmation): $43 profit per order\n⚡ Expected case (60% confirmation): $24 profit per order\n❌ Worst case (40% confirmation): $12 loss per order\n\nNever launch a campaign before Simulation says this is profitable."},{id:6,cat:"Tech",color:"#EF4444",date:"December 20, 2024",time:"7 min read",title:"Risk Management: Know Before It Is Too Late and Save Your Capital",desc:"The system that protects your business from silent losses.",body:"There is a type of loss more dangerous than obvious loss.\nIt is the silent loss bleeding slowly until you are surprised by the end.\n\nA Real Story:\nA merchant noticed rising orders and was happy.\nBut did not notice the return rate climbed from 17% to 39%.\nIn January he had lost $34,000 in 3 months.\n\nUMCEM Instant alerts when:\n⚠️ Return rate exceeds your limit\n⚠️ Any product enters loss zone\n⚠️ Confirmation rate drops below target\n⚠️ Ad costs rise without results\n⚠️ Stock almost out\n\nAlerts via dashboard, SMS and detailed email.\n\nUMCEM makes you always the first to know."}]},
