es:{dir:"ltr",langName:"Español",flag:"🇪🇸",nav:{about:"Nosotros",services:"Servicios",how:"Cómo Funciona",pricing:"Precios",faq:"FAQ",login:"Iniciar Sesión",register:"Registrarse",back:"Volver",contact:"Contacto",terms:"Términos",privacy:"Privacidad",blog:"Blog",help:"Ayuda"},hero:{badge:"La Plataforma N°1 de Gestión E-Commerce",t1:"Tu Independencia",t2:"Comercial Comienza Aquí",sub:"Gestiona tu equipo, analiza tus ganancias y controla tu negocio desde cualquier lugar del mundo.",cta1:"Empezar — 50 Pedidos Gratis",cta2:"Ver Cómo Funciona",s1:"Comerciantes Activos",s2:"Satisfacción del Cliente %",s3:"Pedidos Procesados"},pain:{title:"¿Sabes qué les pasa al 90% de los comerciantes?",sub:"Trabajan duro durante meses... luego descubren la verdad",points:["Venden sin saber su ganancia real","El equipo trabaja sin plan","Sin análisis reales","Quieren expandirse sin herramienta"],solution:"UMCEM resuelve todos estos problemas"},features:{title:"Todo Lo Que Necesitas",sub:"Sistema operativo completo para tu negocio",items:[{title:"Simulación de Ganancias",desc:"Calcula tu ganancia real antes de empezar."},{title:"Gestión del Equipo",desc:"Asigna tareas y da permisos precisos."},{title:"Sistema de Confirmación",desc:"3 días × 3 sesiones × 5 llamadas."},{title:"Conecta Tiendas",desc:"Shopify, YouCan, WooCommerce automáticamente."},{title:"Análisis en Tiempo Real",desc:"Ganancias netas y rendimiento."},{title:"Gestión de Riesgos",desc:"Alertas automáticas."},{title:"Funciona en Cualquier Lugar",desc:"Cualquier mercado y moneda."},{title:"Barra de Motivación",desc:"Interfaz motivadora para agentes."}]},how:{title:"Empieza en 4 Pasos",steps:[{title:"Crea tu Cuenta",desc:"Regístrate en 2 minutos"},{title:"Agrega tus Productos",desc:"Agrega con SKU y precios"},{title:"Conecta tu Tienda",desc:"Copia y pega la clave API"},{title:"Gestiona y Crece",desc:"Decisiones basadas en datos"}]},faq:{title:"Preguntas Frecuentes",items:[{q:"¿Necesito experiencia técnica?",a:"No. Solo copiar y pegar una clave API."},{q:"¿Varias tiendas?",a:"Sí, Shopify, YouCan, WooCommerce."},{q:"¿Cómo funciona la Simulación?",a:"Ingresa precios — muestra 3 escenarios."},{q:"¿Después de la prueba?",a:"Notificación 3 días antes."},{q:"¿Múltiples idiomas?",a:"Árabe, inglés, francés, español, turco."},{q:"¿Datos seguros?",a:"SSL. Nunca compartidos."},{q:"¿Empresas de envío?",a:"Sí, Aramex, DHL, Bosta y otras."},{q:"¿Miembros del equipo?",a:"3 para Básico, 10 para Pro, ilimitado para Negocios."}]},about:{title:"Sobre Nosotros",sub:"UMCEM Nació de una Lucha Real",p1:"Vimos comerciantes descubrir que operaban con pérdidas.",p2:"UMCEM te da independencia comercial completa.",mission:"Nuestra Misión",missionText:"Empoderar a cada comerciante e-commerce para gestionar su negocio profesionalmente.",vision:"Nuestra Visión",visionText:"Ser la plataforma #1 mundial de gestión e-commerce para 2027.",values:"Nuestros Valores",valItems:["Transparencia total","Simplicidad sin compromiso","Seguridad y confiabilidad","Soporte continuo"]},cta:{title:"Comienza Hoy",sub:"50 pedidos gratis — sin cargos",btn:"Empieza Gratis Ahora"},contact:{title:"Contáctanos",sub:"Responderemos en 24 horas.",nameL:"Nombre Completo",nameP:"Tu nombre",emailL:"Correo",emailP:"example@domain.com",subjectL:"Asunto",subjectP:"¿Cómo podemos ayudarte?",msgL:"Mensaje",msgP:"Escribe tu mensaje...",send:"Enviar",sending:"Enviando...",sent:"¡Mensaje enviado!",sentSub:"Te responderemos en 24h.",officeTitle:"Información de Contacto",email:"support@UMCEM.io",phone:"+212 600 000 000",hours:"Disponible 24/7",social:"Síguenos"},terms:{title:"Términos y Condiciones",updated:"Última actualización: Enero 2025",sections:[{title:"1. Aceptación",body:"Al usar UMCEM, aceptas estos términos."},{title:"2. Servicio",body:"UMCEM es una plataforma SaaS para gestionar e-commerce."},{title:"3. Pago",body:"Facturación mensual por adelantado."},{title:"4. Reembolso",body:"Garantía de devolución en 7 días."},{title:"5. Seguridad",body:"Cifrado SSL. Datos no compartidos."},{title:"6. Propiedad intelectual",body:"Todo el contenido es propiedad exclusiva de UMCEM."},{title:"7. Modificaciones",body:"Podemos modificar estos términos con notificación previa."}]},privacy:{title:"Política de Privacidad",updated:"Última actualización: Enero 2025",sections:[{title:"1. Datos recopilados",body:"Información de cuenta, datos de uso, información del dispositivo."},{title:"2. Uso",body:"Para proporcionar y mejorar el servicio."},{title:"3. Compartir",body:"Nunca vendido a terceros con fines de marketing."},{title:"4. Seguridad",body:"SSL, cifrado de base de datos, monitoreo continuo."},{title:"5. Tus derechos",body:"Acceso, corrección, eliminación. Contacto: privacy@UMCEM.io"},{title:"6. Cookies",body:"Para mejorar tu experiencia."},{title:"7. Contacto",body:"privacy@UMCEM.io"}]},help:{title:"Centro de Ayuda",sub:"Todo lo que necesitas saber sobre UMCEM",categories:[{icon:"🚀",title:"Inicio Rápido",desc:"Cómo crear tu cuenta",articles:["Crear cuenta","Conectar Shopify","Conectar YouCan","Conectar WooCommerce","Agregar producto"]},{icon:"👥",title:"Gestión de Equipo",desc:"Agregar miembros",articles:["Agregar agente","Definir permisos","Seguimiento","Distribución auto","Barra motivación"]},{icon:"📊",title:"Análisis",desc:"Leer tus datos",articles:["Panel de análisis","Simulación","Informes PDF","Comparaciones","Análisis productos"]},{icon:"💳",title:"Suscripción",desc:"Pagos y facturas",articles:["Cambiar plan","Actualizar tarjeta","Descargar facturas","Cancelar","Reembolso"]}],contactTitle:"¿No encontraste lo que buscas?",contactSub:"Nuestro equipo está disponible 24/7",contactBtn:"Contactar Soporte"},blog:{title:"Blog",sub:"Últimos artículos para tu éxito e-commerce",posts:[{cat:"Consejos",date:"15 Enero 2025",title:"¿Cómo elevar tu tasa de confirmación al 80%?",desc:"Guía completa de estrategias de confirmación inteligente.",time:"5 min"},{cat:"Análisis",date:"10 Enero 2025",title:"¿Por qué el 90% de los comerciantes online pierden dinero?",desc:"Estudio analítico de las razones del fracaso de los comerciantes.",time:"8 min"},{cat:"Tech",date:"5 Enero 2025",title:"Conectar Shopify con UMCEM: Guía paso a paso",desc:"Cómo conectar tu tienda Shopify en menos de 5 minutos.",time:"4 min"},{cat:"Estrategia",date:"1 Enero 2025",title:"Construir un equipo de ventas exitoso",desc:"Cómo elegir y motivar tu equipo con UMCEM.",time:"6 min"},{cat:"Consejos",date:"28 Diciembre 2024",title:"Simulación de Ganancias: Calcula antes de empezar",desc:"Cómo usar la herramienta Simulación para evaluar cualquier producto.",time:"5 min"},{cat:"Tech",date:"20 Diciembre 2024",title:"Sistema de gestión de riesgos en e-commerce",desc:"Cómo proteger tu negocio de pérdidas.",time:"7 min"}],readMore:"Leer artículo",articles:[{id:1,cat:"Consejos",color:"#00D4AA",date:"15 Enero 2025",time:"5 min",title:"Como elevar tu tasa de confirmacion al 80%?",desc:"Guia psicologica y estrategica para elevar tu tasa de confirmacion.",body:"Gastas en publicidad. Tu equipo llama. Los pedidos llegan.\nLuego descubres que el 40% de tus pedidos han desaparecido.\n\nEsto no es fracaso. Es la ausencia de un sistema.\n\nDia Uno:\n● Intento matutino (8-10 AM)\n● Intento al mediodia (12-2 PM)\n● Intento vespertino (6-8 PM)\n\nDia Dos:\n● Dos intentos con recordatorio SMS\n\nDia Tres:\n● Ultimo intento con oferta especial\n\n✅ Tasa de confirmacion del 43% al 79% en 30 dias\n✅ Ahorro de 3 horas diarias\n\nUMCEM te da este sistema listo desde el primer dia."},{id:2,cat:"Analisis",color:"#EF4444",date:"10 Enero 2025",time:"8 min",title:"Por que el 90% de los comerciantes pierden dinero sin saberlo?",desc:"La dolorosa verdad revelada por la contabilidad correcta.",body:"Este articulo te va a molestar.\nPero podria salvar tu negocio.\n\nUn comerciante vendiendo 400 pedidos a 150 euros\nVentas = 60,000 euros\n\n● Costo producto = 18,000\n● Costo envio = 8,800\n● Devoluciones 25% = 6,700\n● Publicidad = 16,000\n● Salarios = 9,000\n\nTotal = 61,000 euros\n❌ Perdida neta = 1,000 euros por mes!\n\nUMCEM Simulation calcula tu beneficio real antes de vender."},{id:3,cat:"Tech",color:"#818CF8",date:"5 Enero 2025",time:"4 min",title:"Conectar Shopify con UMCEM en 5 minutos",desc:"Guia tecnica paso a paso para conectar tu tienda.",body:"Tu dia sin sistema:\n8:00 AM - Abrir Shopify\n8:15 AM - Copiar a Excel manualmente\n8:45 AM - Enviar por WhatsApp\n\nPasos de conexion:\n1. Shopify luego Settings luego Apps\n2. Develop apps luego Create an app\n3. Nombrar UMCEM, activar Orders read\n4. Copiar token API\n5. UMCEM luego Tiendas luego Anadir\n\n✅ 2-3 horas ahorradas diariamente\n✅ Nunca mas pedidos olvidados"},{id:4,cat:"Estrategia",color:"#F59E0B",date:"1 Enero 2025",time:"6 min",title:"Un equipo sin supervision = negocio sangrando dinero cada dia",desc:"Como descubrir al agente debil antes de que te cueste miles.",body:"Sabes cuantas llamadas hizo cada agente hoy?\n\nSi no - estas perdiendo dinero ahora mismo.\n\nUn agente sin sistema trabaja al 40% de eficiencia.\n\nCon UMCEM:\n● Panel de rendimiento en tiempo real\n● Alerta instantanea cuando baja el rendimiento\n● Informe diario en tu telefono\n\n✅ Tasa de confirmacion del 51% al 76%\n✅ Ventas subieron 43%"},{id:5,cat:"Consejos",color:"#00D4AA",date:"28 Diciembre 2024",time:"5 min",title:"Simulacion: Nunca vendas sin conocer tus numeros",desc:"Como usar los numeros no la suerte para elegir tus productos.",body:"Ejemplo real - Reloj inteligente:\n● Compra: 85 / Venta: 220 / Envio: 25 / Pub: 42 / Devoluciones: 20%\n\nSin Simulacion: 220 - 85 = 135 euros de ganancia!\n\nCon Simulacion:\n✅ Mejor caso (80%): 43 euros ganancia\n⚡ Caso esperado (60%): 24 euros ganancia\n❌ Peor caso (40%): 12 euros de perdida\n\nNunca lances una campana antes de que Simulacion diga rentable."},{id:6,cat:"Tech",color:"#EF4444",date:"20 Diciembre 2024",time:"7 min",title:"Gestion de riesgos: Sabe antes de que sea tarde",desc:"El sistema que protege tu negocio de las perdidas silenciosas.",body:"Hay una perdida mas peligrosa que la obvia.\nEs la perdida silenciosa.\n\nUn comerciante perdio 34,000 euros en 3 meses sin saberlo.\n\nUMCEM alerta automaticamente cuando:\n⚠️ Tasa de devolucion supera tu limite\n⚠️ Producto en zona de perdida\n⚠️ Tasa de confirmacion baja\n⚠️ Costos pub suben sin resultados\n\nAlertas via panel, SMS y email.\nUMCEM te hace siempre el primero en saber."}]},login:{title:"Bienvenido de Nuevo",sub:"Inicia sesión para continuar",eL:"Correo",eP:"example@domain.com",pL:"Contraseña",pP:"Tu contraseña",forgot:"¿Olvidaste tu contraseña?",btn:"Iniciar Sesión",noAcc:"¿No tienes cuenta?",regLink:"Crear Cuenta",brand:"Gestiona tu equipo y analiza ganancias desde cualquier lugar"},reg:{title:"Crea tu Cuenta",sub:"Comienza hacia la independencia",s1:"Información Personal",s2:"Verificación Teléfono y Tarjeta",s3:"Elige tu Plan",fnL:"Nombre",fnP:"ej: Juan",lnL:"Apellido",lnP:"ej: García",eL:"Correo",eP:"example@domain.com",phL:"Teléfono",phP:"Tu número",codeL:"Código",cL:"País",cP:"— Selecciona —",pL:"Contraseña",pP:"8 caracteres mín",bL:"Nombre del Negocio",bP:"ej: Mi Tienda",storeType:"Tipo de Tienda",next:"Siguiente",prev:"Atrás",submit:"Empezar",hasAcc:"¿Ya tienes cuenta?",loginLink:"Iniciar Sesión",docTitle:"Verificación de Identidad",docSub:"Sube un documento (Requerido)",idCard:"DNI",pp:"Pasaporte",front:"Cara Frontal",back:"Cara Trasera",uploadHint:"JPG, PNG o PDF — Máx 5MB",secNote:"Protegido con SSL",done:"¡Cuenta Creada!",doneSub:"Documentos revisados en 24h.",choosePlan:"Elige Tu Plan",errReq:"Completa todos los campos",errPass:"8 caracteres mínimo",errDoc:"Sube un documento válido",bestLabel:"Mejor",chooseFile:"Clic para subir",freeNote:"50 pedidos gratuitos"},pricing:{title:"Elige tu Plan",sub:"50 pedidos gratis — sin cargos",popular:"Más Popular",monthly:"/mes",trialNote:"50 pedidos gratis",payTitle:"Completar Suscripción",cnL:"Número de Tarjeta",cnP:"0000 0000 0000 0000",exL:"Vencimiento",exP:"MM/AA",cvL:"CVV",cvP:"•••",nmL:"Nombre en Tarjeta",nmP:"Nombre completo",payBtn:"Pagar",backBtn:"Atrás",secure:"Pago seguro SSL",orderSum:"Resumen",plan:"Plan",total:"Total",success:"¡Pago Exitoso!",successSub:"Bienvenido a UMCEM.",goDash:"Panel de Control",errCard:"Datos de tarjeta incompletos",features:"Características",startNow:"Empezar",startFree:"Prueba Gratis",contactUs:"Contáctanos",plans:[{id:"s",name:"Básico",en:"Starter",price:"29.99",color:"#64748b",desc:"Para empezar",features:["1.000 pedidos/mes","3 miembros","1 tienda","Análisis básicos","Simulación","Soporte email"],cta:"startNow"},{id:"p",name:"Pro",en:"Pro",price:"59.99",popular:true,color:"#00D4AA",desc:"Para crecer",features:["5.000 pedidos/mes","10 miembros","5 tiendas","Análisis avanzados","Sistema 3 días","Simulación avanzada","SMS auto","Soporte 24/7"],cta:"startFree"},{id:"b",name:"Negocios",en:"Business",price:"99.99",color:"#818CF8",desc:"Para grandes proyectos",features:["Ilimitado","Equipo ilimitado","Tiendas ilimitadas","PDF automático","API completo","Gerente dedicado","White-label","Soporte VIP"],cta:"contactUs"}]},footer:{tagline:"Tu independencia comienza aquí",copy:"© 2025 UMCEM. Todos los derechos reservados.",p:"Plataforma",c:"Empresa",s:"Soporte",pl:["Características","Precios","Simulación","Integraciones"],cl:["Sobre Nosotros","Blog","Socios","Contáctanos"],sl:["Centro de Ayuda","FAQ","Términos y Condiciones","Política de Privacidad"]},
},
tr:{dir:"ltr",langName:"Türkçe",flag:"🇹🇷",nav:{about:"Hakkımızda",services:"Hizmetler",how:"Nasıl Çalışır",pricing:"Fiyatlar",faq:"SSS",login:"Giriş Yap",register:"Kayıt Ol",back:"Geri",contact:"İletişim",terms:"Şartlar",privacy:"Gizlilik",blog:"Blog",help:"Yardım"},hero:{badge:"1 Numaralı E-Ticaret Yönetim Platformu",t1:"Ticari Bağımsızlığınız",t2:"Burada Başlıyor",sub:"Ekibinizi yönetin, karlarınızı analiz edin ve işinizi dünyanın her yerinden kontrol edin.",cta1:"Başla — 50 Ücretsiz Sipariş",cta2:"Nasıl Çalıştığını Gör",s1:"Aktif Satıcı",s2:"Müşteri Memnuniyeti %",s3:"İşlenen Sipariş"},pain:{title:"Satıcıların %90'ına Ne Olduğunu Biliyor musunuz?",sub:"Aylarca çok çalışırlar... sonra gerçeği keşfederler",points:["Gerçek karlarını bilmeden sipariş satarlar","Ekip plan olmadan çalışır","Gerçek analitik yok","Uzaktan yönetim aracı olmadan genişlemek istiyorlar"],solution:"UMCEM tüm bu sorunları çözüyor"},features:{title:"İhtiyacınız Olan Her Şey",sub:"İşletmeniz için tam işletim sistemi",items:[{title:"Kar Simülasyonu",desc:"Başlamadan önce gerçek karınızı hesaplayın."},{title:"Ekip Yönetimi",desc:"Görev atayın ve kesin izinler verin."},{title:"Onay Sistemi",desc:"3 gün × 3 oturum × 5 arama."},{title:"Mağazaları Bağla",desc:"Shopify, YouCan, WooCommerce otomatik."},{title:"Gerçek Zamanlı Analitik",desc:"Net karlar ve ürün performansı."},{title:"Risk Yönetimi",desc:"Otomatik uyarılar."},{title:"Her Yerde Çalışır",desc:"Herhangi bir pazar ve para birimi."},{title:"Motivasyon Çubuğu",desc:"Motive edici ajan arayüzü."}]},how:{title:"4 Adımda Başlayın",steps:[{title:"Hesap Oluşturun",desc:"2 dakikada kaydolun"},{title:"Ürün Ekleyin",desc:"SKU ve fiyatlarla ekleyin"},{title:"Mağazayı Bağlayın",desc:"API Key kopyalayıp yapıştırın"},{title:"Yönetin ve Büyüyün",desc:"Gerçek verilere dayalı kararlar"}]},faq:{title:"Sık Sorulan Sorular",items:[{q:"Teknik deneyim gerekli mi?",a:"Hayır. API Key kopyalayıp yapıştırmak yeterli."},{q:"Birden fazla mağaza?",a:"Evet, Shopify, YouCan, WooCommerce."},{q:"Simülasyon nasıl çalışır?",a:"Fiyatları girin — 3 senaryo gösterilir."},{q:"Ücretsiz deneme sonrası?",a:"3 gün önce bildirim. Gizli ücret yok."},{q:"Birden fazla dil?",a:"Arapça, İngilizce, Fransızca, İspanyolca, Türkçe."},{q:"Veriler güvenli mi?",a:"SSL. Asla paylaşılmaz."},{q:"Kargo şirketleri?",a:"Evet, Aramex, DHL, Bosta ve diğerleri."},{q:"Ekip üyeleri?",a:"Başlangıç için 3, Pro için 10, İş için sınırsız."}]},about:{title:"Hakkımızda",sub:"UMCEM Gerçek Mücadeleden Doğdu",p1:"Satıcıların zarar ederek çalıştığını keşfettiklerini gördük.",p2:"UMCEM tam ticari bağımsızlık için yaratıldı.",mission:"Misyonumuz",missionText:"Her e-ticaret satıcısını profesyonelce yönetmesi için güçlendirmek.",vision:"Vizyonumuz",visionText:"2027'ye kadar 100.000 satıcının başarısına katkıda bulunmak.",values:"Değerlerimiz",valItems:["Tam şeffaflık","Güç kaybetmeden basitlik","Güvenlik ve güvenilirlik","Sürekli destek"]},cta:{title:"Bugün Başlayın",sub:"50 sipariş ücretsiz — kart yok",btn:"Ücretsiz Başla"},contact:{title:"İletişim",sub:"24 saat içinde yanıt vereceğiz.",nameL:"Ad Soyad",nameP:"Adınız",emailL:"E-posta",emailP:"example@domain.com",subjectL:"Konu",subjectP:"Size nasıl yardımcı olabiliriz?",msgL:"Mesaj",msgP:"Mesajınızı yazın...",send:"Gönder",sending:"Gönderiliyor...",sent:"Mesajınız gönderildi!",sentSub:"24 saat içinde e-postanıza yanıt vereceğiz.",officeTitle:"İletişim Bilgileri",email:"support@UMCEM.io",phone:"+212 600 000 000",hours:"7/24 Erişilebilir",social:"Bizi Takip Edin"},terms:{title:"Kullanım Koşulları",updated:"Son güncelleme: Ocak 2025",sections:[{title:"1. Kabul",body:"UMCEM'yi kullanarak bu koşulları kabul etmiş olursunuz."},{title:"2. Hizmet",body:"UMCEM, e-ticaret yönetimi için bir SaaS platformudur."},{title:"3. Ödeme",body:"Aylık peşin faturalama. İstediğiniz zaman iptal edebilirsiniz."},{title:"4. İade",body:"7 gün içinde para iade garantisi."},{title:"5. Güvenlik",body:"SSL şifreleme. Veriler paylaşılmaz."},{title:"6. Fikri mülkiyet",body:"Tüm içerik UMCEM'nin özel mülkiyetindedir."},{title:"7. Değişiklikler",body:"Koşulları önceden bildirimle değiştirebiliriz."}]},privacy:{title:"Gizlilik Politikası",updated:"Son güncelleme: Ocak 2025",sections:[{title:"1. Toplanan veriler",body:"Hesap bilgileri, kullanım verileri, cihaz bilgileri."},{title:"2. Kullanım",body:"Hizmeti sağlamak ve geliştirmek için."},{title:"3. Paylaşım",body:"Pazarlama amaçlı üçüncü taraflara asla satılmaz."},{title:"4. Güvenlik",body:"SSL, veritabanı şifreleme, sürekli izleme."},{title:"5. Haklarınız",body:"Erişim, düzeltme, silme. İletişim: privacy@UMCEM.io"},{title:"6. Çerezler",body:"Deneyiminizi geliştirmek için."},{title:"7. İletişim",body:"privacy@UMCEM.io"}]},help:{title:"Yardım Merkezi",sub:"UMCEM hakkında bilmeniz gereken her şey",categories:[{icon:"🚀",title:"Hızlı Başlangıç",desc:"Hesabınızı nasıl oluşturursunuz",articles:["Hesap oluşturun","Shopify bağlayın","YouCan bağlayın","WooCommerce bağlayın","Ürün ekleyin"]},{icon:"👥",title:"Ekip Yönetimi",desc:"Üye ekleme",articles:["Ajan ekle","İzinleri ayarla","Performans takibi","Otomatik dağıtım","Motivasyon çubuğu"]},{icon:"📊",title:"Analitik",desc:"Verilerinizi okuyun",articles:["Analitik paneli","Kar Simülasyonu","PDF raporları","Karşılaştırmalar","Ürün analizi"]},{icon:"💳",title:"Abonelik",desc:"Ödemeler ve faturalar",articles:["Plan değiştir","Kartı güncelle","Faturaları indir","İptal et","İade talebi"]}],contactTitle:"Aradığınızı bulamadınız mı?",contactSub:"Ekibimiz 7/24 yardıma hazır",contactBtn:"Destekle İletişime Geç"},blog:{title:"Blog",sub:"E-ticaret başarınız için son makaleler",posts:[{cat:"İpuçları",date:"15 Ocak 2025",title:"Onay oranınızı %80'e nasıl yükseltirsiniz?",desc:"Akıllı onay stratejileri için kapsamlı rehber.",time:"5 dk"},{cat:"Analiz",date:"10 Ocak 2025",title:"Neden çevrimiçi satıcıların %90'ı zarar ediyor?",desc:"Satıcıların başarısızlık nedenlerinin analitik çalışması.",time:"8 dk"},{cat:"Teknoloji",date:"5 Ocak 2025",title:"Shopify'ı UMCEM ile bağlama: Adım adım rehber",desc:"Shopify mağazanızı 5 dakikadan kısa sürede nasıl bağlarsınız.",time:"4 dk"},{cat:"Strateji",date:"1 Ocak 2025",title:"Başarılı bir e-ticaret satış ekibi kurmak",desc:"UMCEM araçlarıyla ekibinizi seçmek ve motive etmek.",time:"6 dk"},{cat:"İpuçları",date:"28 Aralık 2024",title:"Kar Simülasyonu: Başlamadan önce hesaplayın",desc:"Herhangi bir ürünü değerlendirmek için Simülasyon aracını nasıl kullanırsınız.",time:"5 dk"},{cat:"Teknoloji",date:"20 Aralık 2024",title:"E-ticarette risk yönetimi sistemi",desc:"İşletmenizi kayıplardan nasıl korursunuz.",time:"7 dk"}],readMore:"Makaleyi Oku",articles:[{id:1,cat:"Ipuclari",color:"#00D4AA",date:"15 Ocak 2025",time:"5 dk",title:"Siparis Onay Oraninizi yüzde 80'e Nasil Cikarirsiniz?",desc:"Onay oraninizi artirmak icin kanitlanmis psikolojik rehber.",body:"Reklama para harciyorsunuz. Ekibiniz ariyor. Siparisler geliyor.\nSonra siparislerinizin yüzde 40'inin kaybolduğunu kesfediyorsunuz.\n\nBu basarisizlik degil. Sistemin yokluğu.\n\nBirinci Gün:\n● Sabah denemesi (08:00-10:00)\n● Öğle denemesi (12:00-14:00)\n● Aksam denemesi (18:00-20:00)\n\nIkinci Gün:\n● SMS hatirlaticiyla iki deneme\n\nUcüncü Gün:\n● Özel teklifle son deneme\n\n30 günde onay orani yüzde 43'ten yüzde 79'a çikti.\nUMCEM bu sistemi ilk günden itibaren hazir sunuyor."},{id:2,cat:"Analiz",color:"#EF4444",date:"10 Ocak 2025",time:"8 dk",title:"Çevrimiçi Saticilar Neden Farkinda Olmadan Zarar Ediyor?",desc:"Dogru muhasebe tarafindan ortaya cikan aci gercek.",body:"Bu makale sizi rahatsiz edecek.\nAma isletmenizi kurtarabilir.\n\n150 euro'ya 400 siparis satan bir satici\nToplam satis = 60,000 euro\n\n● Ürün maliyeti = 18,000\n● Kargo = 8,800\n● Iadeler yüzde 25 = 6,700\n● Reklam = 16,000\n● Maaslar = 9,000\n\nToplam = 61,000 euro\nNet zarar = ayda 1,000 euro!\n\nUMCEM Simulation gercek net kârinizi hesaplar."},{id:3,cat:"Teknoloji",color:"#818CF8",date:"5 Ocak 2025",time:"4 dk",title:"Shopify'i UMCEM ile 5 Dakikada Baglamak",desc:"Magazanizi baglamak icin adim adim teknik rehber.",body:"Sistemsiz gününüz:\n08:00 - Shopify'i aç\n08:15 - Siparisleri Excel'e kopyala\n08:45 - WhatsApp ile gönder\n\nBaglanti Adimlari:\n1. Shopify sonra Settings sonra Apps\n2. Develop apps sonra Create an app\n3. UMCEM olarak adlandir, Orders read'i etkinlestir\n4. API token'i kopyala\n5. UMCEM sonra Magazalar sonra Ekle\n\nHer yeni siparis otomatik geliyor.\n2-3 saat günlük tasarruf."},{id:4,cat:"Strateji",color:"#F59E0B",date:"1 Ocak 2025",time:"6 dk",title:"Denetimsiz Ekip = Her Gün Para Kaybeden Isletme",desc:"Zayif temsilciyi binlerce dolara mal olmadan önce nasil kesfedersiniz.",body:"Ekibinizdeki her temsilcinin bugün kaç arama yaptigini biliyor musunuz?\n\nCevabiniz hayir ise - su an para kaybediyorsunuz.\n\nSistemi olmayan bir temsilci yüzde 40 verimlilikle çalisir.\n\nUMCEM ile:\n● Gerçek zamanli performans paneli\n● Performans düstügünde aninda uyari\n● Telefona günlük rapor\n\nOnay orani yüzde 51'den yüzde 76'ya çikti.\nSatis yüzde 43 artti."},{id:5,cat:"Ipuclari",color:"#00D4AA",date:"28 Aralik 2024",time:"5 dk",title:"Kar Simülasyonu: Bunu Okumadan Ürün Satmayin",desc:"Ürünlerinizi seçmek icin sansça degil rakamlara dayali karar.",body:"Gerçek Örnek - Akilli Saat:\n● Alis: 85 / Satis: 220 / Kargo: 25 / Reklam: 42 / Iade: yüzde 20\n\nSimülasyon olmadan: 220 - 85 = 135 euro kâr!\n\nSimülasyon ile:\nEn iyi durum (yüzde 80): 43 euro kâr\nBeklenen (yüzde 60): 24 euro kâr\nEn kötü (yüzde 40): 12 euro zarar\n\nSimülasyon kârli demeden kampanya baslatmayin."},{id:6,cat:"Teknoloji",color:"#EF4444",date:"20 Aralik 2024",time:"7 dk",title:"Risk Yönetimi: Çok Geç Olmadan Bilin",desc:"Isletmenizi sessiz kayiplardan koruyan sistem.",body:"Bariz kayiptan daha tehlikeli bir kayip türü var.\nSessiz kayip.\n\nBir satici 3 ayda 34,000 euro kaybetti farkinda olmadan.\n\nUMCEM aninda uyarir:\nIade orani limitinizi astinda\nÜrün zarar bölgesine girdiginde\nOnay orani hedefinizin altina düstügünde\nReklam maliyetleri sonuçsuz arttiginda\n\nUMCEM sizi her zaman ilk bilen yapar."}]},login:{title:"Tekrar Hoş Geldiniz",sub:"Devam etmek için giriş yapın",eL:"E-posta",eP:"example@domain.com",pL:"Şifre",pP:"Şifrenizi girin",forgot:"Şifremi unuttum?",btn:"Giriş Yap",noAcc:"Hesabınız yok mu?",regLink:"Kayıt Ol",brand:"Ekibinizi yönetin ve karlarınızı her yerden analiz edin"},reg:{title:"Hesabınızı Oluşturun",sub:"Bağımsızlık yolculuğunuza başlayın",s1:"Kişisel Bilgiler",s2:"Telefon ve Kart Doğrulama",s3:"Planınızı Seçin",fnL:"Ad",fnP:"örn: Ahmet",lnL:"Soyad",lnP:"örn: Yılmaz",eL:"E-posta",eP:"example@domain.com",phL:"Telefon",phP:"Numaranız",codeL:"Kod",cL:"Ülke",cP:"— Ülke Seçin —",pL:"Şifre",pP:"En az 8 karakter",bL:"İşletme Adı",bP:"örn: Elektronik Mağazam",storeType:"Mağaza Türü",next:"İleri",prev:"Geri",submit:"Ücretsiz Başla",hasAcc:"Hesabınız var mı?",loginLink:"Giriş Yap",docTitle:"Kimlik Doğrulama",docSub:"Bir belge yükleyin (Gerekli)",idCard:"Nüfus Cüzdanı",pp:"Pasaport",front:"Ön Yüz",back:"Arka Yüz",uploadHint:"JPG, PNG veya PDF — Maks 5MB",secNote:"SSL ile korunur",done:"Hesap Oluşturuldu!",doneSub:"Belgeler 24 saat içinde incelenir.",choosePlan:"Planınızı Seçin",errReq:"Tüm alanları doldurun",errPass:"En az 8 karakter",errDoc:"Geçerli belge yükleyin",bestLabel:"En İyi",chooseFile:"Yüklemek için tıklayın",freeNote:"50 ücretsiz sipariş"},pricing:{title:"Planınızı Seçin",sub:"50 sipariş ücretsiz — ücret yok",popular:"En Popüler",monthly:"/ay",trialNote:"50 sipariş ücretsiz",payTitle:"Aboneliği Tamamla",cnL:"Kart Numarası",cnP:"0000 0000 0000 0000",exL:"Son Kullanma",exP:"AA/YY",cvL:"CVV",cvP:"•••",nmL:"Kart Adı",nmP:"Tam ad",payBtn:"Öde",backBtn:"Geri",secure:"256-bit SSL güvenli ödeme",orderSum:"Özet",plan:"Plan",total:"Toplam",success:"Ödeme Başarılı!",successSub:"UMCEM'ye hoş geldiniz.",goDash:"Kontrol Paneli",errCard:"Eksik kart bilgileri",features:"Özellikler",startNow:"Şimdi Başla",startFree:"Ücretsiz Dene",contactUs:"İletişim",plans:[{id:"s",name:"Başlangıç",en:"Starter",price:"29.99",color:"#64748b",desc:"Başlamak için",features:["1.000 sipariş/ay","3 üye","1 mağaza","Temel analitik","Simülasyon","E-posta desteği"],cta:"startNow"},{id:"p",name:"Pro",en:"Pro",price:"59.99",popular:true,color:"#00D4AA",desc:"Büyümek için",features:["5.000 sipariş/ay","10 üye","5 mağaza","Gelişmiş analitik","3 günlük sistem","Gelişmiş simülasyon","Otomatik SMS","7/24 destek"],cta:"startFree"},{id:"b",name:"İş",en:"Business",price:"99.99",color:"#818CF8",desc:"Büyük projeler",features:["Sınırsız sipariş","Sınırsız ekip","Sınırsız mağaza","PDF raporları","API","Özel yönetici","White-label","VIP"],cta:"contactUs"}]},footer:{tagline:"Bağımsızlığınız burada başlıyor",copy:"© 2025 UMCEM. Tüm hakları saklıdır.",p:"Platform",c:"Şirket",s:"Destek",pl:["Özellikler","Fiyatlar","Simülasyon","Entegrasyonlar"],cl:["Hakkımızda","Blog","Ortaklar","İletişim"],sl:["Yardım Merkezi","SSS","Kullanım Koşulları","Gizlilik Politikası"]},
},
};

const FICONS=[BarChart2,Users,PhoneCall,Link2,TrendingUp,ShieldAlert,Globe,Award];
const FCOLORS=["#00D4AA","#818CF8","#F59E0B","#06B6D4","#00D4AA","#EF4444","#818CF8","#F59E0B"];
const PICONS=[DollarSign,AlertTriangle,PieChart,MapPin];
const SICONS=[UserPlus,Package,Link2,TrendingUp];
const PCOLS=["#64748b","#00D4AA","#818CF8"];
const LANGS=Object.keys(T);

function fmtCard(v){return v.replace(/\D/g,"").slice(0,16).replace(/(.{4})/g,"$1 ").trim();}
function fmtExp(v){const d=v.replace(/\D/g,"").slice(0,4);return d.length>=3?d.slice(0,2)+"/"+d.slice(2):d;}

function AnimatedNumber({target,suffix=""}){
  const [n,setN]=useState(0);const ref=useRef(null);const done=useRef(false);
  useEffect(()=>{
    const ob=new IntersectionObserver(([e])=>{
      if(e.isIntersecting&&!done.current){done.current=true;let v=0;const inc=target/100;
        const tm=setInterval(()=>{v+=inc;if(v>=target){setN(target);clearInterval(tm);}else setN(Math.floor(v));},16);}
    },{threshold:0.3});
    if(ref.current)ob.observe(ref.current);return()=>ob.disconnect();
  },[target]);
  const fmt=n>=1000000?(n/1000000).toFixed(1)+"M+":n>=1000?n.toLocaleString()+"+":n+suffix;
  return <span ref={ref}>{fmt}</span>;
}

/* ── Language Dropdown ── */
function LangDrop({lang,setLang,C,dark}){
  const [open,setOpen]=useState(false);const ref=useRef(null);
  useEffect(()=>{const h=e=>{if(ref.current&&!ref.current.contains(e.target))setOpen(false);};document.addEventListener("mousedown",h);return()=>document.removeEventListener("mousedown",h);},[]);
  return(
    <div ref={ref} style={{position:"relative"}}>
      <button onClick={()=>setOpen(!open)} style={{display:"flex",alignItems:"center",gap:6,padding:"7px 12px",borderRadius:9,border:`1px solid ${C.border}`,background:C.card,color:C.text,cursor:"pointer",fontSize:13,fontWeight:700,whiteSpace:"nowrap",transition:"all .2s"}}>
        <span style={{fontSize:16}}>{T[lang].flag}</span>
        <span>{T[lang].langName}</span>
        <ChevronDown size={12} color={C.muted} style={{transition:"transform .2s",transform:open?"rotate(180deg)":"rotate(0)"}} strokeWidth={2}/>
      </button>
      {open&&(
        <div style={{position:"absolute",top:"calc(100% + 8px)",right:0,minWidth:170,background:dark?"#12122a":"#fff",border:`1px solid ${C.border}`,borderRadius:12,boxShadow:"0 8px 32px rgba(0,0,0,0.2)",overflow:"hidden",zIndex:9999}}>
          {LANGS.map(l=>(
            <button key={l} onClick={()=>{setLang(l);setOpen(false);}} style={{width:"100%",display:"flex",alignItems:"center",gap:10,padding:"10px 16px",background:lang===l?"rgba(0,212,170,0.10)":"transparent",border:"none",color:lang===l?"#00D4AA":C.sub,cursor:"pointer",fontSize:13,fontWeight:lang===l?800:500,transition:"background .15s"}}>
              <span style={{fontSize:16}}>{T[l].flag}</span><span>{T[l].langName}</span>
              {lang===l&&<Check size={13} color="#00D4AA" strokeWidth={3} style={{marginRight:"auto"}}/>}
            </button>
          ))}
        </div>
      )}
    </div>
  );
}

/* ── Upload Box ── */
function UploadBox({label,preview,onUpload,t,C}){
  const ref=useRef(null);
  return(
    <div>
      <div style={{fontSize:12,fontWeight:700,marginBottom:7,color:C.muted}}>{label}</div>
      <div onClick={()=>ref.current?.click()} style={{border:"2px dashed rgba(0,212,170,0.35)",borderRadius:12,padding:"20px 12px",textAlign:"center",cursor:"pointer",transition:"all .2s"}} onMouseEnter={e=>e.currentTarget.style.borderColor="rgba(0,212,170,0.65)"} onMouseLeave={e=>e.currentTarget.style.borderColor="rgba(0,212,170,0.35)"}>
        {preview?(<div>{preview.startsWith("data:image")?<img src={preview} alt="" style={{maxHeight:68,maxWidth:"100%",borderRadius:6,marginBottom:5}}/>:<FileText size={30} color="#00D4AA" strokeWidth={1.5} style={{marginBottom:5}}/>}<div style={{fontSize:11,color:"#00D4AA",fontWeight:700}}>✓ {t.chooseFile}</div></div>):(
          <div><Upload size={24} color="rgba(0,212,170,0.6)" strokeWidth={1.5} style={{marginBottom:6}}/><div style={{fontSize:12,fontWeight:600,color:"rgba(0,212,170,0.8)",marginBottom:3}}>{t.chooseFile}</div><div style={{fontSize:10,color:C.muted}}>{t.uploadHint}</div></div>
        )}
      </div>
      <input ref={ref} type="file" accept="image/jpeg,image/png,application/pdf" style={{display:"none"}} onChange={e=>{const f=e.target.files?.[0];if(!f)return;const r=new FileReader();r.onload=ev=>onUpload(ev.target.result);r.readAsDataURL(f);}}/>
    </div>
  );
}

/* ════════════════════════════════════════════
   MAIN APP
════════════════════════════════════════════ */
export default function UMCEM(){
  // ✅ Arabic is always the default language
  const [dark,setDark]=useState(true);
  const [lang,setLang]=useState("ar");
  const [page,setPage]=useState("home");
  const [scrolled,setScrolled]=useState(false);
  const [mobileMenu,setMobileMenu]=useState(false);
  const [faqOpen,setFaqOpen]=useState(null);
  const [rStep,setRStep]=useState(1);
  const [rForm,setRForm]=useState({fn:"",ln:"",email:"",phoneCode:"+212",phone:"",country:"",pass:"",biz:""});
  const [docType,setDocType]=useState("id");
  const [docs,setDocs]=useState({idF:null,idB:null,pp:null});
  const [rPlan,setRPlan]=useState("محترف");
  const [rErr,setRErr]=useState("");
  const [rDone,setRDone]=useState(false);
  const [lEmail,setLEmail]=useState("");const [lPass,setLPass]=useState("");
  const [showP,setShowP]=useState(false);const [lErr,setLErr]=useState("");const [lLoad,setLLoad]=useState(false);
  const [pView,setPView]=useState("plans");
  const [selPlan,setSelPlan]=useState(null);
  const [selArt,setSelArt]=useState(null);
  
  const [card,setCard]=useState({num:"",exp:"",cvc:"",name:""});
  const [cardErr,setCardErr]=useState("");const [payLoad,setPayLoad]=useState(false);const [payDone,setPayDone]=useState(false);
  const [codeOpen,setCodeOpen]=useState(false);const codeRef=useRef(null);
  const [contactForm,setContactForm]=useState({name:"",email:"",subject:"",msg:""});
  const [contactSent,setContactSent]=useState(false);const [contactLoad,setContactLoad]=useState(false);

  const t=T[lang];const isRtl=t.dir==="rtl";const A="#00D4AA";

  useEffect(()=>{const h=()=>setScrolled(window.scrollY>60);window.addEventListener("scroll",h);return()=>window.removeEventListener("scroll",h);},[]);
  useEffect(()=>{setRPlan(t.pricing.plans[1].name);},[lang]);
  useEffect(()=>{window.scrollTo(0,0);},[page]);
  useEffect(()=>{const h=e=>{if(codeRef.current&&!codeRef.current.contains(e.target))setCodeOpen(false);};document.addEventListener("mousedown",h);return()=>document.removeEventListener("mousedown",h);},[]);

  const C=dark?{bg:"#06060f",bgS:"#0a0a1c",card:"rgba(255,255,255,0.045)",border:"rgba(255,255,255,0.09)",text:"#f1f5f9",sub:"rgba(241,245,249,0.65)",muted:"rgba(241,245,249,0.32)",nav:scrolled?"rgba(6,6,15,0.96)":"transparent",inp:"rgba(255,255,255,0.055)",inpB:"rgba(255,255,255,0.13)",ph:"rgba(241,245,249,0.28)",cardSh:"none",drop:"#12122a"}
  :{bg:"#ffffff",bgS:"#f4f7ff",card:"#ffffff",border:"rgba(15,23,42,0.10)",text:"#0f172a",sub:"#374151",muted:"#6b7280",nav:scrolled?"rgba(255,255,255,0.97)":"transparent",inp:"#f8fafc",inpB:"rgba(15,23,42,0.14)",ph:"#9ca3af",cardSh:"0 2px 16px rgba(15,23,42,0.07)",drop:"#ffffff"};

  const bi={width:"100%",padding:"11px 14px",borderRadius:10,background:C.inp,border:`1px solid ${C.inpB}`,color:C.text,fontFamily:"inherit",fontSize:14,outline:"none",transition:"border-color .2s",boxSizing:"border-box"};

  const goPage=(p)=>{setPage(p);setMobileMenu(false);window.scrollTo(0,0);};

  const BackBtn=()=>(
    <button onClick={()=>goPage("home")} style={{display:"inline-flex",alignItems:"center",gap:7,background:"transparent",border:`1px solid ${C.border}`,color:C.sub,cursor:"pointer",fontSize:14,fontWeight:600,marginBottom:28,padding:"8px 16px",borderRadius:9,transition:"all .2s"}} onMouseEnter={e=>{e.currentTarget.style.borderColor=A;e.currentTarget.style.color=A;}} onMouseLeave={e=>{e.currentTarget.style.borderColor=C.border;e.currentTarget.style.color=C.sub;}}>
      {isRtl?<ArrowRight size={15} strokeWidth={2}/>:<ArrowLeft size={15} strokeWidth={2}/>}{t.nav.back}
    </button>
  );

  /* ── NAV ── */
  const Nav=(
    <nav style={{position:"fixed",top:0,left:0,right:0,zIndex:1000,background:C.nav,backdropFilter:scrolled?"blur(20px)":"none",borderBottom:scrolled?`1px solid ${C.border}`:"none",boxShadow:scrolled?(dark?"0 4px 24px rgba(0,0,0,0.5)":"0 4px 24px rgba(0,0,0,0.07)"):"none",transition:"all .3s",padding:"0 5%",display:"flex",alignItems:"center",justifyContent:"space-between",height:68}}>
      <button onClick={()=>goPage("home")} style={{display:"flex",alignItems:"center",gap:9,background:"transparent",border:"none",cursor:"pointer",color:C.text,padding:0}}>
        <span style={{fontWeight:900,fontSize:22,letterSpacing:-1}}><span style={{background:"linear-gradient(135deg,#00D4AA,#818CF8)",WebkitBackgroundClip:"text",WebkitTextFillColor:"transparent"}}>UM</span><span style={{color:C.text}}>CEM</span></span>
      </button>
      {/* ✅ Language switcher ONLY in navbar — removed from footer */}
      <div className="dn" style={{display:"flex",gap:24,fontSize:14,fontWeight:600,alignItems:"center"}}>
        {page==="home"&&[["about",t.nav.about],["services",t.nav.services],["howItWorks",t.nav.how],["pricing-sec",t.nav.pricing],["faq",t.nav.faq]].map(([id,label])=>(
          <a key={id} href={`#${id}`} style={{color:C.sub,textDecoration:"none",transition:"color .2s"}} onMouseEnter={e=>e.target.style.color=A} onMouseLeave={e=>e.target.style.color=C.sub}>{label}</a>
        ))}
      </div>
      <div className="dn" style={{display:"flex",alignItems:"center",gap:8}}>
        {/* ✅ Single language switcher here only */}
        <LangDrop lang={lang} setLang={setLang} C={C} dark={dark}/>
        <button onClick={()=>setDark(!dark)} style={{width:36,height:36,borderRadius:9,border:`1px solid ${C.border}`,background:C.card,cursor:"pointer",display:"flex",alignItems:"center",justifyContent:"center"}}>
          {dark?<Sun size={16} color={C.sub} strokeWidth={2}/>:<Moon size={16} color={C.sub} strokeWidth={2}/>}
        </button>
        <button onClick={()=>goPage("login")} style={{padding:"8px 16px",borderRadius:9,background:"transparent",border:`1.5px solid ${C.border}`,color:C.text,cursor:"pointer",fontSize:13,fontWeight:700,display:"flex",alignItems:"center",gap:6,transition:"all .2s"}} onMouseEnter={e=>{e.currentTarget.style.borderColor=A;e.currentTarget.style.color=A;}} onMouseLeave={e=>{e.currentTarget.style.borderColor=C.border;e.currentTarget.style.color=C.text;}}>
          <LogIn size={14} strokeWidth={2}/>{t.nav.login}
        </button>
        <button onClick={()=>{goPage("register");setRStep(1);setRErr("");setRDone(false);}} style={{padding:"8px 16px",borderRadius:9,background:"linear-gradient(135deg,#00D4AA,#818CF8)",border:"none",color:"#fff",cursor:"pointer",fontSize:13,fontWeight:800,display:"flex",alignItems:"center",gap:6,boxShadow:"0 4px 14px rgba(0,212,170,0.35)"}}>
          <UserPlus size={14} strokeWidth={2}/>{t.nav.register}
        </button>
      </div>
      <button className="mb" onClick={()=>setMobileMenu(!mobileMenu)} style={{background:"transparent",border:"none",color:C.text,cursor:"pointer",display:"none"}}>
        {mobileMenu?<X size={24}/>:<Menu size={24}/>}
      </button>
    </nav>
  );

  const MM=mobileMenu&&(
    <div style={{position:"fixed",top:68,left:0,right:0,zIndex:999,background:dark?"#0d0d24":"#fff",borderBottom:`1px solid ${C.border}`,padding:"18px 5%",display:"flex",flexDirection:"column",gap:12,boxShadow:"0 8px 24px rgba(0,0,0,0.15)"}}>
      {page==="home"&&[["about",t.nav.about],["services",t.nav.services],["howItWorks",t.nav.how],["pricing-sec",t.nav.pricing],["faq",t.nav.faq]].map(([id,label])=>(
        <a key={id} href={`#${id}`} onClick={()=>setMobileMenu(false)} style={{color:C.sub,textDecoration:"none",fontSize:15,fontWeight:600,padding:"8px 0",borderBottom:`1px solid ${C.border}`}}>{label}</a>
      ))}
      <div style={{display:"flex",alignItems:"center",gap:10,padding:"8px 0"}}>
        <LangDrop lang={lang} setLang={setLang} C={C} dark={dark}/>
        <button onClick={()=>setDark(!dark)} style={{width:36,height:36,borderRadius:9,border:`1px solid ${C.border}`,background:C.card,cursor:"pointer",display:"flex",alignItems:"center",justifyContent:"center"}}>
          {dark?<Sun size={16} color={C.sub} strokeWidth={2}/>:<Moon size={16} color={C.sub} strokeWidth={2}/>}
        </button>
      </div>
      <div style={{display:"flex",gap:10}}>
        <button onClick={()=>goPage("login")} style={{flex:1,padding:"11px",borderRadius:9,background:"transparent",border:`1.5px solid ${C.border}`,color:C.text,cursor:"pointer",fontSize:14,fontWeight:700}}>{t.nav.login}</button>
        <button onClick={()=>{goPage("register");setRStep(1);setRErr("");setRDone(false);}} style={{flex:1,padding:"11px",borderRadius:9,background:"linear-gradient(135deg,#00D4AA,#818CF8)",border:"none",color:"#fff",cursor:"pointer",fontSize:14,fontWeight:800}}>{t.nav.register}</button>
      </div>
    </div>
  );

  /* ════════════════ FOOTER ════════════════ */
  /* ✅ No language switcher here — it's only in the navbar */
  const Footer=(
    <footer style={{padding:"48px 5% 22px",borderTop:`1px solid ${C.border}`,background:C.bg}}>
      <div style={{maxWidth:1200,margin:"0 auto"}}>
        <div style={{display:"grid",gridTemplateColumns:"repeat(auto-fit,minmax(170px,1fr))",gap:32,marginBottom:36}}>
          <div>
            <button onClick={()=>goPage("home")} style={{display:"flex",alignItems:"center",gap:9,marginBottom:12,background:"transparent",border:"none",cursor:"pointer",color:C.text,padding:0}}>
              <span style={{fontWeight:900,fontSize:21,letterSpacing:-1}}><span style={{background:"linear-gradient(135deg,#00D4AA,#818CF8)",WebkitBackgroundClip:"text",WebkitTextFillColor:"transparent"}}>UM</span><span style={{color:C.text}}>CEM</span></span>
            </button>
            <p style={{color:C.sub,fontSize:13,lineHeight:1.7,maxWidth:210}}>{t.footer.tagline}</p>
